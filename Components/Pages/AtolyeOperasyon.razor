        }
        catch (Exception ex) { Snackbar.Add("Hata: " + ex.Message, Severity.Error); }
    }

    // --- Toplu Atama ---

    private void TopluAtamaModunaGec()
    {
        _planAtamalari = _islerBekleyen.ToDictionary(x => x.Id, _ => (int?)null);

        _planKapasitesi = new();
        _egitimModu = false;
        _topluAtamaModu = true;
    }

    private void TopluAtamaModundanCik()
    {
        _topluAtamaModu = false;
        _planAtamalari.Clear();

        _planKapasitesi.Clear();
    }

    private double KalanKapasite(int personelId) =>
        NetVardiyaSuresi
        - _kapasiteHaritasi.GetValueOrDefault(personelId)
        - _planKapasitesi.GetValueOrDefault(personelId);

    // İşlem türüne göre minimum yetkinlik seviyesi
    // Kritik: SV3+ zorunlu  |  diğer (Rutin, Periyodik vb.): SV1+ (herhangi sertifika yeterli)
    private static int MinYetkinlikSeviyesi(string? islemTuru) =>
        (islemTuru ?? "").ToLower() == "kritik" ? 3 : 1;

    private int AciliyetPuaniHesapla(BakimKontrolKaydi is_)
    {
        int puan = (is_.ParcaSablonu?.IslemTuru ?? "").ToLower() switch
        {
            "kritik"    => 60,
            "rutin"     => 20,
            "periyodik" => 15,
            _           => 10
        };
        var gunFarki = (int)(DateTime.UtcNow - is_.IslemTarihi).TotalDays;
        puan += Math.Min(gunFarki * 5, 50);
        return Math.Min(puan, 110);
    }

    private List<PersonelPuani> UygunPersonelListesi(BakimKontrolKaydi is_)
    {
        var parcaPN = is_.ParcaSablonu?.ParcaPN ?? "";
        var atolyeKodu = is_.ParcaSablonu?.BakimGrubu?.AtolyeKodu ?? "";
        var islemTuru = is_.ParcaSablonu?.IslemTuru;
        var gereklSure = (is_.ParcaSablonu?.IslemSure ?? 60) / 60.0;
        var minSeviye = MinYetkinlikSeviyesi(islemTuru);
        var bugun = DateTime.UtcNow.Date;

        return _personeller.Select(p =>
        {
            if (p.Durum != "Aktif")
                return new PersonelPuani(p, 0, false, "Aktif değil", 0);

            if (p.IzinBaslangic.HasValue && p.IzinBitis.HasValue
                && bugun >= p.IzinBaslangic.Value.Date && bugun <= p.IzinBitis.Value.Date)
                return new PersonelPuani(p, 0, false, "İzinde", 0);

            if (!string.IsNullOrEmpty(atolyeKodu) && !string.IsNullOrEmpty(p.AtolyeKodu)
                && !p.AtolyeKodu.Trim().Equals(atolyeKodu.Trim(), StringComparison.OrdinalIgnoreCase))
                return new PersonelPuani(p, 0, false, "Farklı atölye", 0);

            var yetkinlik = _yetkinlikler.FirstOrDefault(y => y.SicilNo == p.SicilNo && y.ParcaPN == parcaPN);
            if (yetkinlik == null)
                return new PersonelPuani(p, 0, false, "Sertifika yok", 0);

            if (yetkinlik.YetkinlikSeviyesi < minSeviye)
                return new PersonelPuani(p, 0, false,
                    $"SV yetersiz — {islemTuru} için min. SV{minSeviye} gerekli", yetkinlik.YetkinlikSeviyesi);

            if (KalanKapasite(p.Id) < gereklSure)
                return new PersonelPuani(p, 0, false, "Kapasitesi dolu", 0);

            int puan = yetkinlik.YetkinlikSeviyesi switch { 5 => 60, 4 => 50, 3 => 40, 2 => 30, 1 => 20, _ => 10 };

            if (!string.IsNullOrEmpty(atolyeKodu)
                && p.AtolyeKodu?.Trim().Equals(atolyeKodu.Trim(), StringComparison.OrdinalIgnoreCase) == true)
                puan += 30;

            var aktifIs = GetPersonelAktifIsSayisi(p.Id);
            puan += aktifIs == 0 ? 20 : aktifIs == 1 ? 10 : 0;

            return new PersonelPuani(p, puan, true, null, yetkinlik.YetkinlikSeviyesi);
        })
        .OrderByDescending(x => x.UygunMu)
        .ThenByDescending(x => x.UyumPuani)
        .ToList();
    }

    private void PlanAtamayiGuncelle(int isId, int? yeniPersonelId)
    {
        var is_ = _islerBekleyen.FirstOrDefault(x => x.Id == isId);
        var sure = (is_?.ParcaSablonu?.IslemSure ?? 60) / 60.0;

        if (_planAtamalari.TryGetValue(isId, out var eskiId) && eskiId.HasValue)
            _planKapasitesi[eskiId.Value] = Math.Max(0, _planKapasitesi.GetValueOrDefault(eskiId.Value) - sure);

        _planAtamalari[isId] = yeniPersonelId;


        if (yeniPersonelId.HasValue)
        {
            _planKapasitesi[yeniPersonelId.Value] = _planKapasitesi.GetValueOrDefault(yeniPersonelId.Value) + sure;
        }
    }

    private void OtomatikDagit()
    {
        _planKapasitesi.Clear();
        _planAtamalari = _islerBekleyen.ToDictionary(x => x.Id, _ => (int?)null);


        foreach (var is_ in _islerBekleyen.OrderByDescending(x => AciliyetPuaniHesapla(x)))
        {
            var uygunlar = UygunPersonelListesi(is_).Where(x => x.UygunMu).ToList();
            if (!uygunlar.Any()) continue;

            var toplamSure = ((is_.ParcaSablonu?.IslemSure ?? 60) + (is_.ParcaSablonu?.HazirlikSuresi ?? 15)) / 60.0;
            var enIyi = uygunlar.FirstOrDefault(x =>
                (_planKapasitesi.GetValueOrDefault(x.Personel.Id) + toplamSure) <= NetVardiyaSuresi);
            if (enIyi is null) continue;  // Hiçbir personele sığmıyor, pas geç

            _planAtamalari[is_.Id] = enIyi.Personel.Id;
            _planKapasitesi[enIyi.Personel.Id] = _planKapasitesi.GetValueOrDefault(enIyi.Personel.Id) + toplamSure;
        }

        Snackbar.Add("Otomatik dağılım tamamlandı.", Severity.Info);
    }

    private void PlanTemizle()
    {
        _planAtamalari = _islerBekleyen.ToDictionary(x => x.Id, _ => (int?)null);

        _planKapasitesi.Clear();
    }

    private void PlanOnayGoster() => _onayDialogAcik = true;

    private async Task PlanOnayla()
    {
        int sayac = 0;
        foreach (var (isId, personelId) in _planAtamalari)
        {
            if (!personelId.HasValue) continue;
            var kayit = _tumIsler.FirstOrDefault(x => x.Id == isId);
            if (kayit == null) continue;

            kayit.AtananPersonelId = personelId;
            kayit.Durum = nameof(BakimDurumu.DevamEdiyor);
            kayit.IslemTarihi = DateTime.UtcNow;
            kayit.EgitimModu = _egitimModu;
            sayac++;
        }

        try
        {
            await Context.SaveChangesAsync();
            Snackbar.Add($"{sayac} iş başarıyla atandı.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Kayıt hatası: " + ex.Message, Severity.Error);
            return;
        }

        _onayDialogAcik = false;
        _topluAtamaModu = false;
        _planAtamalari.Clear();

        _planKapasitesi.Clear();
        await VerileriYukle();
    }

    private int RiskSkoru()
    {
        var atanmamis = _islerBekleyen.Count(x =>
            !_planAtamalari.TryGetValue(x.Id, out var v) || !v.HasValue);

        var dusukSeviye = _planAtamalari.Count(kv =>
        {
            if (!kv.Value.HasValue) return false;
            var is_ = _islerBekleyen.FirstOrDefault(x => x.Id == kv.Key);
            var p = _personeller.FirstOrDefault(x => x.Id == kv.Value.Value);
            var yetk = _yetkinlikler.FirstOrDefault(y => y.SicilNo == p?.SicilNo && y.ParcaPN == is_?.ParcaSablonu?.ParcaPN);
            return yetk?.YetkinlikSeviyesi <= 2;
        });

        return atanmamis * 15 + dusukSeviye * 10;
    }

    private List<Personel> PersonelKartlariListesi()
    {
        var atolye = _atolyeler.FirstOrDefault(a => a.Id == _seciliAtolyeId);
        return _personeller
            .Where(p => p.Durum == "Aktif" && p.AtolyeKodu == atolye?.AtolyeKodu)
            .OrderBy(p => p.AdSoyad)
            .ToList();
    }

