@page "/atolye-operasyon"
@using MudBlazor
@using MroPlan.Models
@using MroPlan.Models.Enums
@using MroPlan.Services
@using MroPlan.Data
@using Microsoft.EntityFrameworkCore
@implements IDisposable
@inject IBakimService BakimService
@inject IYetkinlikService YetkinlikService
@inject ISnackbar Snackbar
@inject ApplicationDbContext Context
@inject ZamanYonetimServisi ZamanServisi
@inject IYillikPlanlamaService OptimizasyonService


<MudContainer MaxWidth="@MaxWidth.False" Class="mt-6 animate-fade-in">
    <div class="d-flex align-center justify-space-between mb-8">
        <div>
            <MudText Typo="Typo.h4" Style="font-weight: 900; letter-spacing: -1.5px;">Atölye Operasyonları</MudText>
            <MudText Typo="Typo.subtitle1" Style="color: rgba(255,255,255,0.5);">Atölye bazlı iş yükü ve personel dağılımını yönetin.</MudText>
        </div>
    </div>

    <MudGrid Spacing="4">
        @foreach (var atolye in _atolyeler)
        {
            var pSayi = GetPersonelSayisi(atolye.AtolyeKodu);
            var iSayi = GetIsSayisi(atolye.Id);
            var personelIdleri = _personeller.Where(p => p.AtolyeKodu == atolye.AtolyeKodu).Select(p => p.Id).ToHashSet();
            var atananSayisi = _tumIsler
                .Where(x => x.ParcaSablonu?.BakimGrubuId == atolye.Id
                         && x.Durum == nameof(BakimDurumu.DevamEdiyor)
                         && x.AtananPersonelId.HasValue
                         && personelIdleri.Contains(x.AtananPersonelId.Value))
                .Select(x => x.AtananPersonelId!.Value)
                .Distinct().Count();
            var atanmayanSayisi = pSayi - atananSayisi;
            // Utilization: aktif + bekleyen toplam iş yükü / aylık kapasite
            // 408 dk = 8s × 60 × 0.85 (ILP ve senaryo ile tutarlı)
            // Kapasite: personel × 20 iş günü/ay × 408 dk/gün
            var toplamIsYukuDk = _tumIsler
                .Where(x => x.ParcaSablonu?.BakimGrubuId == atolye.Id
                         && (x.Durum == nameof(BakimDurumu.DevamEdiyor) || x.Durum == nameof(BakimDurumu.Beklemede)))
                .Sum(x => x.ParcaSablonu?.IslemSure ?? 60);
            var aylikKapasiteDk = pSayi > 0 ? pSayi * 20 * 408 : 408;
            var dolulukOrani = (int)Math.Min(toplamIsYukuDk / (double)aylikKapasiteDk * 100, 100);
            // Backlog: Beklemede olan iş sayısı
            var backlogSayi = _tumIsler.Count(x => x.ParcaSablonu?.BakimGrubuId == atolye.Id && x.Durum == nameof(BakimDurumu.Beklemede));

            <MudItem xs="12" sm="6" md="3">
                <div class="atolye-card-wrapper">
                    <MudPaper Class="@GetAtolyeClass(atolye.Id, dolulukOrani)" @onclick="@(() => AtolyeSec(atolye))" Elevation="0">
                        <div class="d-flex justify-space-between align-start mb-2">
                            <div class="atolye-icon-box">
                                <MudIcon Icon="@GetAtolyeIcon(atolye.GrupAdi)" Size="Size.Medium" />
                            </div>
                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.3); font-weight: 700;">#@atolye.AtolyeKodu</MudText>
                        </div>
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 800; line-height: 1.2;" Class="mb-2">@atolye.GrupAdi</MudText>
                        <div class="mt-2 mb-4">
                            <div class="d-flex justify-space-between mb-1">
                                <MudText Typo="Typo.caption" Style="font-weight: 700; color: rgba(255,255,255,0.45);">İş Yükü</MudText>
                                <MudText Typo="Typo.caption" Style="@($"font-weight: 700; color: {(dolulukOrani > 80 ? "#ef4444" : "#3b82f6")}")">@dolulukOrani%</MudText>
                            </div>
                            <MudProgressLinear Color="@(dolulukOrani > 80 ? Color.Error : Color.Primary)" Value="@dolulukOrani" Class="rounded-pill" Style="height: 6px;" />
                        </div>
                        <div class="d-flex justify-space-between mt-auto pt-3 border-t">
                            <div class="stat-group">
                                <MudText Typo="Typo.h6" Style="font-weight: 900; font-size: 1.1rem;">@pSayi</MudText>
                                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.3); font-weight: 600;">Personel</MudText>
                            </div>
                            <div class="stat-group text-center">
                                <MudText Typo="Typo.h6" Style="font-weight: 900; font-size: 1.1rem;">@iSayi</MudText>
                                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.3); font-weight: 600;">Aktif İş</MudText>
                            </div>
                            <div class="stat-group text-right">
                                <MudText Typo="Typo.h6" Style="@($"font-weight: 900; font-size: 1.1rem; color: {(backlogSayi > 0 ? "#facc15" : "rgba(255,255,255,0.3)")}")">@backlogSayi</MudText>
                                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.3); font-weight: 600;">Beklemede</MudText>
                            </div>
                        </div>
                        <div class="d-flex justify-space-between mt-2 pt-2" style="border-top: 1px solid rgba(255,255,255,0.05);">
                            <div class="d-flex align-center gap-1">
                                <div style="width:7px; height:7px; border-radius:50%; background:#4ade80; flex-shrink:0;"></div>
                                <MudText Typo="Typo.caption" Style="font-weight:700; color:#4ade80;">@atananSayisi Atanan</MudText>
                            </div>
                            <div class="d-flex align-center gap-1">
                                <div style="width:7px; height:7px; border-radius:50%; background:rgba(255,255,255,0.2); flex-shrink:0;"></div>
                                <MudText Typo="Typo.caption" Style="@($"font-weight:700; color:{(atanmayanSayisi > 0 ? "rgba(255,255,255,0.4)" : "rgba(255,255,255,0.2)")};")">@atanmayanSayisi Atanmayan</MudText>
                            </div>
                        </div>
                        @if (atolye.Id == _seciliAtolyeId)
                        {
                            <div class="active-indicator"></div>
                        }
                    </MudPaper>
                </div>
            </MudItem>
        }
    </MudGrid>

    @if (_seciliAtolyeId > 0)
    {
        @if (!_topluAtamaModu && !_vardiyaModu)
        {
            @* --- KANBAN PANOSU --- *@
            <div class="animate-slide-up mt-12 mb-12">
                <div class="d-flex align-center gap-3 mb-6">
                    <MudIcon Icon="@Icons.Material.Filled.Dashboard" Color="Color.Primary" />
                    <MudText Typo="Typo.h5" Style="font-weight: 900;">İş Akış Panosu</MudText>
                    <div class="flex-1"></div>
                    @if (_islerBekleyen.Any())
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Warning"
                                   StartIcon="@Icons.Material.Rounded.AutoAwesome"
                                   OnClick="OptimalAtamaAcAsync"
                                   Disabled="_optYukleniyor"
                                   Style="font-weight:900; border-radius:12px;">
                            @if (_optYukleniyor)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Hesaplanıyor...</span>
                            }
                            else
                            {
                                <span>OPTİMAL PERSONEL ATA</span>
                            }
                        </MudButton>
                    }
                </div>

                <MudGrid Spacing="4">
                    @* Sütun: BEKLEYEN *@
                    <MudItem xs="12" md="4">
                        <div class="kanban-column">
                            <div class="column-header mb-4 d-flex align-center justify-space-between">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 800; color: rgba(255,255,255,0.4);">BEKLEYEN</MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Filled">@_islerBekleyen.Count</MudChip>
                            </div>
                            <div class="column-content">
                                @foreach (var item in _islerBekleyen)
                                {
                                    <div class="task-card">
                                        <div class="d-flex justify-space-between mb-3">
                                            <div class="d-flex align-center">
                                                <MudIcon Icon="@Icons.Material.Filled.Flight" Size="Size.Small" Color="Color.Primary" Class="mr-2"/>
                                                <MudText Typo="Typo.body2" Style="font-weight: 800;">@item.BakimPlani?.SeriNo</MudText>
                                            </div>
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Class="pa-0" Style="font-size: 0.6rem; color: rgba(255,255,255,0.3);">#@item.Id</MudChip>
                                        </div>
                                        <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.8); font-weight: 600;" Class="mb-1">@item.ParcaSablonu?.ParcaAdi</MudText>
                                        <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.4);">P/N: @item.ParcaSablonu?.ParcaPN</MudText>
                                    </div>
                                }
                            </div>
                        </div>
                    </MudItem>

                    @* Sütun: DEVAM EDEN *@
                    <MudItem xs="12" md="4">
                        <div class="kanban-column active-column">
                            <div class="column-header mb-4 d-flex align-center justify-space-between">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 800; color: #38bdf8;">İŞLEMDE</MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">@_islerDevamEden.Count</MudChip>
                            </div>
                            <div class="column-content">
                                @foreach (var item in _islerDevamEden)
                                {
                                    <div class="task-card in-progress">
                                        <div class="d-flex justify-space-between mb-3">
                                            <div class="d-flex align-center">
                                                <MudIcon Icon="@Icons.Material.Filled.Flight" Size="Size.Small" Color="Color.Info" Class="mr-2"/>
                                                <MudText Typo="Typo.body2" Style="font-weight: 800;">@item.BakimPlani?.SeriNo</MudText>
                                            </div>
                                            <div class="d-flex align-center gap-1">
                                                @if (item.EgitimModu)
                                                {
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text" Style="font-size: 0.55rem; font-weight: 900; padding: 0 6px;">EĞİTİM</MudChip>
                                                }
                                                <div class="pulse-dot"></div>
                                            </div>
                                        </div>
                                        <MudText Typo="Typo.body2" Style="color: #7dd3fc; font-weight: 700;" Class="mb-1">@item.ParcaSablonu?.ParcaAdi</MudText>
                                        <div class="mt-2 d-flex align-center">
                                            <MudAvatar Size="Size.Small" Color="Color.Info" Style="font-size: 0.6rem;" Class="mr-2">@(item.AtananPersonel?.Ad?.Length > 0 ? item.AtananPersonel.Ad[0] : '?')</MudAvatar>
                                            <MudText Typo="Typo.caption" Style="font-weight: 700; color: rgba(255,255,255,0.7);">@item.AtananPersonel?.AdSoyad</MudText>
                                        </div>
                                        <div class="mt-3 pt-2 border-t d-flex justify-end gap-1">
                                            <MudTooltip Text="Atamayı Kaldır">
                                                <MudIconButton Icon="@Icons.Material.Filled.PersonRemove" Color="Color.Warning" Size="Size.Small" OnClick="@(() => AtamayiKaldir(item))" />
                                            </MudTooltip>
                                            <MudTooltip Text="İşi Tamamla">
                                                <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" OnClick="@(() => IsBitir(item))" />
                                            </MudTooltip>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </MudItem>

                    @* Sütun: TAMAMLANAN *@
                    <MudItem xs="12" md="4">
                        <div class="kanban-column">
                            <div class="column-header mb-4 d-flex align-center justify-space-between">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 800; color: #4ade80;">TAMAMLANAN</MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">@_islerBiten.Count</MudChip>
                            </div>
                            <div class="column-content">
                                @foreach (var item in _islerBiten)
                                {
                                    <div class="task-card completed">
                                        <div class="d-flex align-center mb-2">
                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" Class="mr-2"/>
                                            <MudText Typo="Typo.body2" Style="font-weight: 800; color: #22c55e; text-decoration: line-through;">@item.BakimPlani?.SeriNo</MudText>
                                        </div>
                                        <MudText Typo="Typo.caption" Style="color: #4ade80; font-weight: 600;">@item.ParcaSablonu?.ParcaAdi tamamlandı.</MudText>
                                        <div class="mt-3 d-flex justify-end">
                                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.3);">@item.IslemTarihi.ToShortDateString()</MudText>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </MudItem>
                </MudGrid>
            </div>
        }
        else if (_vardiyaModu)
        {
            @* --- VARDİYA PLANI --- *@
            <div class="animate-slide-up mt-10">
                <div class="d-flex align-center gap-3 mb-8">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="VardiyaModundanCik" Color="Color.Default" />
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Color="Color.Info" />
                    <MudText Typo="Typo.h5" Style="font-weight: 900;">Vardiya Planı</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">
                        @_vardiyaAtamalari.Values.SelectMany(x => x).Count() / @_islerBekleyen.Count iş planlandı
                    </MudChip>
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">
                        @_vardiyaAtamalari.Count(x => x.Value.Any()) aktif personel
                    </MudChip>
                    <div class="flex-1"></div>
                    <MudButton Variant="Variant.Outlined" Color="Color.Info"
                               StartIcon="@Icons.Material.Filled.Shuffle"
                               OnClick="VardiyaYenidenDagit"
                               Style="border-radius: 10px; font-weight: 700;">
                        Yeniden Dağıt
                    </MudButton>
                </div>

                @* Özet bilgi şeridi *@
                <div class="vp-ozet-serit mb-6">
                    @{
                        var atananIsler = _vardiyaAtamalari.Values.SelectMany(x => x).Count();
                        var atanmamisIsler = _islerBekleyen.Count - atananIsler;
                        var aktifPersonelSayisi = _vardiyaAtamalari.Count(x => x.Value.Any());
                        var bostaPerson = _vardiyaAtamalari.Count(x => !x.Value.Any());
                    }
                    <div class="vp-ozet-kart" style="border-color: rgba(34,197,94,0.3);">
                        <div style="font-size:1.4rem; font-weight:900; color:#4ade80;">@atananIsler</div>
                        <div style="font-size:0.6rem; color:rgba(255,255,255,0.4); font-weight:700;">ATANAN İŞ</div>
                    </div>
                    @if (atanmamisIsler > 0)
                    {
                        <div class="vp-ozet-kart" style="border-color: rgba(239,68,68,0.3);">
                            <div style="font-size:1.4rem; font-weight:900; color:#ef4444;">@atanmamisIsler</div>
                            <div style="font-size:0.6rem; color:rgba(255,255,255,0.4); font-weight:700;">ATANAMAYAN İŞ</div>
                        </div>
                    }
                    <div class="vp-ozet-kart" style="border-color: rgba(56,189,248,0.3);">
                        <div style="font-size:1.4rem; font-weight:900; color:#38bdf8;">@aktifPersonelSayisi</div>
                        <div style="font-size:0.6rem; color:rgba(255,255,255,0.4); font-weight:700;">ÇALIŞAN PERSONEL</div>
                    </div>
                    @if (bostaPerson > 0)
                    {
                        <div class="vp-ozet-kart" style="border-color: rgba(250,204,21,0.3);">
                            <div style="font-size:1.4rem; font-weight:900; color:#facc15;">@bostaPerson</div>
                            <div style="font-size:0.6rem; color:rgba(255,255,255,0.4); font-weight:700;">BOŞ PERSONEL</div>
                        </div>
                    }
                </div>

                @* Personel kartları grid *@
                <div class="vp-grid">
                    @foreach (var kvp in _vardiyaAtamalari.OrderByDescending(x => x.Value.Count).ThenBy(x =>
                        _personeller.FirstOrDefault(p => p.Id == x.Key)?.AdSoyad))
                    {
                        var p = _personeller.FirstOrDefault(x => x.Id == kvp.Key);
                        if (p == null) continue;
                        var mevcutKap = _kapasiteHaritasi.GetValueOrDefault(p.Id);
                        var planlananDk = kvp.Value.Sum(is_ => is_.ParcaSablonu?.IslemSure ?? 60) / 60.0;
                        var toplamDolu = mevcutKap + planlananDk;
                        var dolulukPct = (int)Math.Min(toplamDolu / NetVardiyaSuresi * 100, 100);
                        var bos = !kvp.Value.Any();

                        <div class="vp-personel-kart @(bos ? "vp-kart-bos" : "")">
                            @* Personel başlık *@
                            <div class="d-flex align-center gap-3 mb-4">
                                <MudAvatar Size="Size.Medium"
                                           Color="@(bos ? Color.Default : dolulukPct > 80 ? Color.Error : Color.Success)"
                                           Style="font-weight:900; font-size:0.9rem;">
                                    @(p.Ad.Length > 0 ? p.Ad[0] : '?')
                                </MudAvatar>
                                <div class="flex-1">
                                    <div style="font-weight:800; font-size:0.85rem;">@p.AdSoyad</div>
                                    <div style="color:rgba(255,255,255,0.35); font-size:0.65rem;">@p.Unvan</div>
                                </div>
                                @if (bos)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text"
                                             Style="font-size:0.6rem; font-weight:700; color:rgba(255,255,255,0.3);">BOŞ</MudChip>
                                }
                                else
                                {
                                    <span style="font-size:0.75rem; font-weight:900;
                                        color:@(dolulukPct > 80 ? "#ef4444" : dolulukPct > 50 ? "#facc15" : "#4ade80");">
                                        @dolulukPct%
                                    </span>
                                }
                            </div>

                            @* Kapasite bar *@
                            <div style="background:rgba(255,255,255,0.04); border-radius:6px; height:5px; overflow:hidden; margin-bottom:12px;">
                                <div style="height:100%; float:left; border-radius:6px;
                                     width:@(Math.Min((int)(mevcutKap/NetVardiyaSuresi*100),100))%;
                                     background:rgba(59,130,246,0.7);"></div>
                                <div style="height:100%; float:left; border-radius:6px;
                                     width:@(Math.Min((int)(planlananDk/NetVardiyaSuresi*100), 100-(int)(mevcutKap/NetVardiyaSuresi*100)))%;
                                     background:rgba(250,204,21,0.7);"></div>
                            </div>

                            @* Atanan işler *@
                            @if (kvp.Value.Any())
                            {
                                <div class="d-flex flex-column gap-2">
                                    @foreach (var is_ in kvp.Value.OrderByDescending(x => AciliyetPuaniHesapla(x)))
                                    {
                                        var aciliyet = AciliyetPuaniHesapla(is_);

                                        <div class="vp-is-karti" style="border-left: 3px solid @AciliyetRenkKod(aciliyet);">
                                            <div class="d-flex justify-space-between align-start mb-1">
                                                <div style="font-size:0.72rem; font-weight:700;">@is_.ParcaSablonu?.ParcaAdi</div>
                                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                                               Style="padding:0; width:18px; height:18px; color:rgba(255,255,255,0.3);"
                                                               OnClick="@(() => VardiyaIsKaldir(kvp.Key, is_))" />
                                            </div>
                                            <div style="font-size:0.6rem; color:rgba(255,255,255,0.35);">
                                                @is_.ParcaSablonu?.IslemTuru · @is_.ParcaSablonu?.IslemSure dk · @is_.BakimPlani?.SeriNo
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div style="text-align:center; padding:16px; color:rgba(255,255,255,0.15); font-size:0.72rem;">
                                    <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Small" />
                                    <div>Atanacak iş yok</div>
                                </div>
                            }
                        </div>
                    }
                </div>

                @* Atanamayan işler *@
                @{
                    var atanmisIsIdler = _vardiyaAtamalari.Values.SelectMany(x => x).Select(x => x.Id).ToHashSet();
                    var atanmayanIsler = _islerBekleyen.Where(x => !atanmisIsIdler.Contains(x.Id)).ToList();
                }
                @if (atanmayanIsler.Any())
                {
                    <div class="vp-atanmayan-serit mt-6">
                        <div class="d-flex align-center gap-2 mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Small" />
                            <MudText Typo="Typo.subtitle2" Style="color:#ef4444; font-weight:800;">
                                ATANAMAYAN İŞLER (@atanmayanIsler.Count) — Sertifika veya kapasite yetersizliği
                            </MudText>
                        </div>
                        <div style="display:flex; flex-wrap:wrap; gap:8px;">
                            @foreach (var is_ in atanmayanIsler)
                            {
                                <div style="padding:8px 12px; background:rgba(239,68,68,0.08); border:1px solid rgba(239,68,68,0.2); border-radius:10px; font-size:0.7rem;">
                                    <div style="font-weight:700; color:#fca5a5;">@is_.ParcaSablonu?.ParcaAdi</div>
                                    <div style="color:rgba(255,255,255,0.3);">@is_.ParcaSablonu?.ParcaPN · @is_.BakimPlani?.SeriNo</div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @* Footer *@
                <div class="ta-footer mt-8">
                    <MudSwitch @bind-Value="_egitimModu" Color="Color.Info" Style="margin:0;">
                        <MudText Typo="Typo.body2" Style="@($"font-weight:700; color:{(_egitimModu ? "#38bdf8" : "rgba(255,255,255,0.4)")}")">
                            Eğitim Modu @(_egitimModu ? "AÇIK" : "KAPALI")
                        </MudText>
                    </MudSwitch>
                    <div class="flex-1"></div>
                    <MudButton Variant="Variant.Outlined" OnClick="VardiyaModundanCik"
                               Style="border-radius:10px; font-weight:700;">İptal</MudButton>
                    @{
                        var planlanmisVardiya = _vardiyaAtamalari.Values.SelectMany(x => x).Count();
                    }
                    <MudButton Variant="Variant.Filled" Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.CheckCircle"
                               OnClick="VardiyaPlaniniOnayla"
                               Disabled="@(planlanmisVardiya == 0)"
                               Style="border-radius:10px; font-weight:800;">
                        Planı Onayla (@planlanmisVardiya iş)
                    </MudButton>
                </div>
            </div>
        }
        else
        {
            @* --- TOPLU ATAMA PLANI --- *@
            <div class="animate-slide-up mt-10">
                <div class="d-flex align-center gap-3 mb-6">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="TopluAtamaModundanCik" Color="Color.Default" />
                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Secondary" />
                    <MudText Typo="Typo.h5" Style="font-weight: 900;">Toplu Atama Planı</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled">@_islerBekleyen.Count bekleyen iş</MudChip>
                </div>

                @{
                    var atolye = _atolyeler.FirstOrDefault(a => a.Id == _seciliAtolyeId);
                    var egitimdePersonel = _personeller
                        .Where(p => p.AtolyeKodu == atolye?.AtolyeKodu && p.Durum == "Egitimde")
                        .ToList();
                }
                @if (egitimdePersonel.Any())
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-4" Style="border-radius:12px;">
                        <strong>@egitimdePersonel.Count personel eğitimde</strong> — bu atölyede görev alamaz:
                        @string.Join(", ", egitimdePersonel.Select(p => p.AdSoyad))
                    </MudAlert>
                }

                <div class="ta-layout">
                    @* Sol: İş Tablosu *@
                    <div class="ta-sol">
                        <MudText Typo="Typo.subtitle2" Class="mb-3" Style="color: rgba(255,255,255,0.5); font-weight: 700; letter-spacing: 0.05em;">İŞ LİSTESİ — ACİLİYETE GÖRE SIRALANDI</MudText>
                        <div class="ta-tablo-container">
                            @foreach (var item in _islerBekleyen.OrderByDescending(x => AciliyetPuaniHesapla(x)))
                            {
                                var currentItem = item;
                                var aciliyet = AciliyetPuaniHesapla(currentItem);
                                var uygunlar = GetUygunlar(currentItem);
                                var secilenId = _planAtamalari.GetValueOrDefault(currentItem.Id);
                                var sure = currentItem.ParcaSablonu?.IslemSure ?? 60;

                                <div class="ta-is-satiri">
                                    @* Aciliyet badge *@
                                    <div class="ta-aciliyet" style="@AciliyetRengi(aciliyet)">
                                        <span style="font-weight: 900; font-size: 0.9rem;">@aciliyet</span>
                                        <span style="font-size: 0.55rem; opacity: 0.8;">ACİL</span>
                                    </div>

                                    @* İş bilgisi *@
                                    <div class="ta-is-bilgi">
                                        <div style="font-weight: 700; font-size: 0.85rem;">@currentItem.ParcaSablonu?.ParcaAdi</div>
                                        <div style="color: rgba(255,255,255,0.4); font-size: 0.7rem;">
                                            @currentItem.ParcaSablonu?.IslemTuru · @sure dk · @currentItem.BakimPlani?.SeriNo
                                        </div>
                                    </div>

                                    @* Personel seçimi *@
                                    <div class="ta-personel-sec">
                                        <MudSelect T="int?" Value="@secilenId"
                                                   ValueChanged="@((v) => PlanAtamayiGuncelle(currentItem.Id, v))"
                                                   Dense="true" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                   Placeholder="Teknisyen seç..."
                                                   Style="min-width: 200px;">
                                            <MudSelectItem T="int?" Value="@((int?)null)">— Atanmamış —</MudSelectItem>
                                            @foreach (var pp in uygunlar.Where(x => x.UygunMu).OrderByDescending(x => x.UyumPuani))
                                            {
                                                <MudSelectItem T="int?" Value="@((int?)pp.Personel.Id)">
                                                    ✓ @pp.Personel.AdSoyad (Sv@pp.YetkinlikSeviyesi · @pp.UyumPuani pt)
                                                </MudSelectItem>
                                            }
                                            @foreach (var pp in uygunlar.Where(x => !x.UygunMu))
                                            {
                                                <MudSelectItem T="int?" Value="@((int?)pp.Personel.Id)" Disabled="true">
                                                    ✗ @pp.Personel.AdSoyad — @pp.AtanamaSebebi
                                                </MudSelectItem>
                                            }
                                        </MudSelect>

                                    </div>

                                    @* Durum ikonu *@
                                    <div class="ta-durum-ikon">
                                        @if (!secilenId.HasValue)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.RadioButtonUnchecked" Style="color: rgba(255,255,255,0.2);" Size="Size.Small" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    @* Sağ: Personel Kapasite Kartları *@
                    <div class="ta-sag">
                        <MudText Typo="Typo.subtitle2" Class="mb-3" Style="color: rgba(255,255,255,0.5); font-weight: 700; letter-spacing: 0.05em;">PERSONEL KAPASİTESİ</MudText>
                        @foreach (var p in PersonelKartlariListesi())
                        {
                            var mevcut = _kapasiteHaritasi.GetValueOrDefault(p.Id);
                            var planlanan = _planKapasitesi.GetValueOrDefault(p.Id);
                            var toplam = mevcut + planlanan;
                            var doluluk = (int)Math.Min(toplam / NetVardiyaSuresi * 100, 100);
                            var atananIsler = _planAtamalari.Count(kv => kv.Value == p.Id);
                            var yetkinlikler = _yetkinliklerBySicil.GetValueOrDefault(p.SicilNo ?? "", new());

                            <div class="ta-personel-kart">
                                <div class="d-flex align-center mb-2">
                                    <MudAvatar Size="Size.Small" Color="@GetPersonelAvatarColor((int)toplam)" Class="mr-2" Style="font-size: 0.75rem; font-weight: 900;">
                                        @(p.Ad.Length > 0 ? p.Ad[0] : '?')
                                    </MudAvatar>
                                    <div class="flex-1">
                                        <div style="font-weight: 700; font-size: 0.8rem;">@p.AdSoyad</div>
                                        <div style="color: rgba(255,255,255,0.35); font-size: 0.65rem;">@p.Unvan · @atananIsler planlı iş</div>
                                    </div>
                                    <div style="font-weight: 900; font-size: 0.75rem; color: @(doluluk > 80 ? "#ef4444" : doluluk > 50 ? "#facc15" : "#4ade80");">
                                        @doluluk%
                                    </div>
                                </div>
                                <div style="background: rgba(255,255,255,0.05); border-radius: 6px; height: 6px; overflow: hidden;">
                                    <div style="height: 100%; border-radius: 6px; width: @(Math.Min((int)(mevcut/NetVardiyaSuresi*100), 100))%; background: rgba(59,130,246,0.7); float: left;"></div>
                                    <div style="height: 100%; border-radius: 6px; width: @(Math.Min((int)(planlanan/NetVardiyaSuresi*100), 100 - (int)(mevcut/NetVardiyaSuresi*100)))%; background: rgba(250,204,21,0.7); float: left;"></div>
                                </div>
                                <div class="d-flex justify-space-between mt-1">
                                    <div style="font-size: 0.6rem; color: rgba(255,255,255,0.25);">
                                        <span style="color: #3b82f6;">■</span> @mevcut.ToString("F1")s mevcut
                                        <span style="color: #facc15; margin-left: 4px;">■</span> @planlanan.ToString("F1")s planlı
                                    </div>
                                    <div style="font-size: 0.6rem; color: rgba(255,255,255,0.25);">@yetkinlikler.Count sertifika</div>
                                </div>
                            </div>
                        }
                        @if (!PersonelKartlariListesi().Any())
                        {
                            <div style="text-align: center; padding: 32px; color: rgba(255,255,255,0.2);">
                                <MudIcon Icon="@Icons.Material.Filled.GroupOff" Size="Size.Large" />
                                <MudText Typo="Typo.caption" Class="mt-2">Bu atölye için aktif personel yok.</MudText>
                            </div>
                        }
                    </div>
                </div>

                @* Footer *@
                <div class="ta-footer">
                    <MudSwitch @bind-Value="_egitimModu" Color="Color.Info" Style="margin: 0;">
                        <MudText Typo="Typo.body2" Style="@($"font-weight: 700; color: {(_egitimModu ? "#38bdf8" : "rgba(255,255,255,0.4)")};" )">
                            Eğitim Modu @(_egitimModu ? "AÇIK" : "KAPALI")
                        </MudText>
                    </MudSwitch>

                    @{
                        var atanmamisSayisi = _islerBekleyen.Count(x =>
                            !_planAtamalari.TryGetValue(x.Id, out var v) || !v.HasValue);
                    }
                    @if (atanmamisSayisi > 0)
                    {
                        <MudText Typo="Typo.caption" Style="color: #ef4444; font-weight: 700;">
                            @atanmamisSayisi iş atanmamış
                        </MudText>
                    }

                    <div class="flex-1"></div>

                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.AutoAwesome"
                               OnClick="OtomatikDagit"
                               Style="border-radius: 10px; font-weight: 700;">
                        Otomatik Dağıt
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default"
                               StartIcon="@Icons.Material.Filled.ClearAll"
                               OnClick="PlanTemizle"
                               Style="border-radius: 10px; font-weight: 700;">
                        Temizle
                    </MudButton>
                    @{
                        var planlananSayisi = _planAtamalari.Count(kv => kv.Value.HasValue);
                    }
                    <MudButton Variant="Variant.Filled" Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.CheckCircle"
                               OnClick="PlanOnayGoster"
                               Disabled="@(planlananSayisi == 0)"
                               Style="border-radius: 10px; font-weight: 800;">
                        Planı Onayla (@planlananSayisi iş)
                    </MudButton>
                </div>
            </div>
        }
    }

    @* --- OPTİMAL ATAMA ÖNİZLEME PANELI (iki sütun: atama listesi + personel rotası) --- *@
    @if (_optOnizlemeAcik && _optSonuc != null)
    {
        var personelGruplari = _optSonuc.AtamaDetaylari
            .GroupBy(a => a.PersonelId)
            .OrderBy(g => g.First().PersonelAdi)
            .ToList();

        <div class="py-backdrop" @onclick="() => _optOnizlemeAcik = false"></div>
        <div class="py-panel-container" style="max-width:min(95vw,1380px);">
            <div class="py-panel" style="max-height:88vh; overflow:hidden; display:flex; flex-direction:column; padding:28px 32px;">

                @* ── Başlık ────────────────────────────────────────────── *@
                <div class="d-flex align-center justify-space-between mb-4" style="flex-shrink:0;">
                    <div>
                        <MudText Typo="Typo.h5" Style="font-weight:900; color:#FACC15;">OPTİMAL PERSONEL ATAMA</MudText>
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.4);">
                            ILP modeli sonucu — %@_optSonuc.OptimallikSkoru optimallik · Z=@_optSonuc.HedefFonksiyonZ
                        </MudText>
                    </div>
                    <MudIconButton Icon="@Icons.Material.Rounded.Close" Color="Color.Default"
                                   OnClick="() => _optOnizlemeAcik = false" />
                </div>

                @* ── Özet KPI şeridi ──────────────────────────────────── *@
                <div class="d-flex gap-3 mb-4" style="flex-shrink:0;">
                    <div style="flex:1; padding:10px 12px; background:rgba(34,197,94,0.1); border-radius:10px; border:1px solid rgba(34,197,94,0.25); text-align:center;">
                        <div style="font-size:1.5rem; font-weight:900; color:#4ade80;">@_optSonuc.AtananGorev</div>
                        <div style="font-size:0.65rem; color:rgba(255,255,255,0.4); font-weight:700;">ATANACAK</div>
                    </div>
                    <div style="flex:1; padding:10px 12px; background:rgba(239,68,68,0.1); border-radius:10px; border:1px solid rgba(239,68,68,0.25); text-align:center;">
                        <div style="font-size:1.5rem; font-weight:900; color:#f87171;">@_optSonuc.AtanamayaGorev</div>
                        <div style="font-size:0.65rem; color:rgba(255,255,255,0.4); font-weight:700;">ATANAMAYAN</div>
                    </div>
                    <div style="flex:1; padding:10px 12px; background:rgba(250,204,21,0.1); border-radius:10px; border:1px solid rgba(250,204,21,0.25); text-align:center;">
                        <div style="font-size:1.5rem; font-weight:900; color:#FACC15;">@_optSonuc.AktifPersonelSayisi</div>
                        <div style="font-size:0.65rem; color:rgba(255,255,255,0.4); font-weight:700;">AKTİF PERSONEL</div>
                    </div>
                    <div style="flex:1; padding:10px 12px; background:rgba(139,92,246,0.1); border-radius:10px; border:1px solid rgba(139,92,246,0.25); text-align:center;">
                        <div style="font-size:1.5rem; font-weight:900; color:#a78bfa;">@personelGruplari.Count</div>
                        <div style="font-size:0.65rem; color:rgba(255,255,255,0.4); font-weight:700;">ATANAN PERSONEL</div>
                    </div>
                </div>

                @* ── İki sütun gövde ─────────────────────────────────── *@
                <div style="display:flex; gap:20px; flex:1; overflow:hidden; min-height:0;">

                    @* SOL: Atama listesi *@
                    <div style="flex:0 0 340px; overflow-y:auto; padding-right:4px;">
                        @if (_optSonuc.AtamaDetaylari.Any())
                        {
                            <div style="font-size:0.65rem; color:rgba(255,255,255,0.35); font-weight:900; letter-spacing:1px; margin-bottom:8px;">
                                ÖNERİLEN ATAMALAR
                                <span style="color:rgba(255,255,255,0.2); font-weight:400; margin-left:4px;">— rotayı görmek için tıkla</span>
                            </div>
                            <div style="display:flex; flex-direction:column; gap:6px;">
                                @foreach (var atama in _optSonuc.AtamaDetaylari)
                                {
                                    bool secili = _rotaSeciliPersonelId == atama.PersonelId;
                                    <div @onclick="() => _rotaSeciliPersonelId = (_rotaSeciliPersonelId == atama.PersonelId ? 0 : atama.PersonelId)"
                                         style="@($"padding:10px 12px; border-radius:10px; cursor:pointer; transition:all 0.15s; border:1px solid {(secili ? "rgba(250,204,21,0.4)" : "rgba(34,197,94,0.12)")}; background:{(secili ? "rgba(250,204,21,0.07)" : "rgba(34,197,94,0.05)")};")">
                                        <div class="d-flex align-center gap-2">
                                            <MudAvatar Size="Size.Small" Style="@($"background:{(secili ? "rgba(250,204,21,0.3)" : "rgba(250,204,21,0.15)")}; color:#FACC15; font-weight:900; font-size:0.6rem; flex-shrink:0; width:28px; height:28px;")">
                                                @(atama.PersonelAdi.Length > 0 ? atama.PersonelAdi[0].ToString() : "?")
                                            </MudAvatar>
                                            <div style="flex:1; min-width:0;">
                                                <div style="font-size:0.78rem; font-weight:700; color:white; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                                    @atama.PersonelAdi
                                                    <span style="color:rgba(255,255,255,0.25); font-size:0.65rem; font-weight:400; margin-left:4px;">@atama.SicilNo</span>
                                                </div>
                                                <div style="font-size:0.68rem; color:rgba(255,255,255,0.45); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@atama.ParcaAdi</div>
                                            </div>
                                            <div class="d-flex align-center gap-1" style="flex-shrink:0;">
                                                <span style="font-size:0.65rem; padding:2px 6px; border-radius:6px; background:rgba(250,204,21,0.15); color:#FACC15; font-weight:900;">SV@(atama.AtananSv)</span>
                                                <span style="font-size:0.65rem; color:rgba(255,255,255,0.25);">@atama.IslemSureDk dk</span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        @* Atanamayan görevler *@
                        @if (_optSonuc.Atanamayalar.Any())
                        {
                            <div style="font-size:0.65rem; color:rgba(239,68,68,0.7); font-weight:900; letter-spacing:1px; margin:14px 0 8px;">ATANAMAYAN GÖREVLER</div>
                            <div style="display:flex; flex-direction:column; gap:5px;">
                                @foreach (var kayit in _optSonuc.Atanamayalar)
                                {
                                    <div style="padding:8px 12px; background:rgba(239,68,68,0.06); border-radius:8px; border:1px solid rgba(239,68,68,0.15);">
                                        <div class="d-flex align-center gap-2">
                                            <MudIcon Icon="@Icons.Material.Rounded.ErrorOutline" Size="Size.Small" Style="color:#f87171; flex-shrink:0; font-size:0.9rem;" />
                                            <div>
                                                <span style="font-size:0.75rem; font-weight:700; color:white;">@kayit.ParcaAdi</span>
                                                <span style="font-size:0.65rem; color:#f87171; margin-left:6px;">@kayit.Neden</span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @* SAĞ: Personel Rota Planı *@
                    <div style="flex:1; overflow-y:auto; border-left:1px solid rgba(255,255,255,0.06); padding-left:20px; min-width:0;">
                        <div style="font-size:0.65rem; color:rgba(255,255,255,0.35); font-weight:900; letter-spacing:1px; margin-bottom:12px;">PERSONEL ROTA PLANI</div>

                        @if (!personelGruplari.Any())
                        {
                            <div style="text-align:center; padding:40px; color:rgba(255,255,255,0.2);">Atama bulunamadı</div>
                        }
                        else
                        {
                            <div style="display:flex; flex-direction:column; gap:14px;">
                                @foreach (var grup in personelGruplari)
                                {
                                    var gorevler = grup
                                        .OrderBy(g => g.RotaGrubu ?? "\uffff")  // null grup sona
                                        .ThenBy(g => g.SiraNo)
                                        .ThenByDescending(g => g.IslemSureDk)   // SiraNo=0 eski veri fallback
                                        .ToList();
                                    int toplamYuk = gorevler.Sum(g => g.IslemSureDk);
                                    int kapasite = gorevler.First().Kapasite;
                                    double doluluk = kapasite > 0 ? Math.Min(toplamYuk * 100.0 / kapasite, 100) : 0;
                                    bool vurgulu = _rotaSeciliPersonelId == 0 || _rotaSeciliPersonelId == grup.Key;
                                    string renk = doluluk >= 90 ? "#f87171" : doluluk >= 70 ? "#FACC15" : "#4ade80";

                                    <div style="@($"border-radius:14px; border:1px solid {(vurgulu ? "rgba(250,204,21,0.25)" : "rgba(255,255,255,0.05)")}; background:{(vurgulu ? "rgba(15,20,30,0.95)" : "rgba(15,20,30,0.5)")}; padding:14px 16px; transition:all 0.2s; opacity:{(vurgulu ? "1" : "0.4")};")">

                                        @* Personel başlık + yük barı *@
                                        <div class="d-flex align-center justify-space-between mb-3">
                                            <div class="d-flex align-center gap-2">
                                                <MudAvatar Size="Size.Small" Style="background:rgba(250,204,21,0.2); color:#FACC15; font-weight:900; font-size:0.65rem; width:30px; height:30px;">
                                                    @(gorevler.First().PersonelAdi[0].ToString())
                                                </MudAvatar>
                                                <div>
                                                    <div style="font-size:0.8rem; font-weight:800; color:white;">@gorevler.First().PersonelAdi</div>
                                                    <div style="font-size:0.62rem; color:rgba(255,255,255,0.35);">@gorevler.First().SicilNo · @gorevler.Count görev · @toplamYuk dk</div>
                                                </div>
                                            </div>
                                            <div style="text-align:right;">
                                                <div style="@($"font-size:0.8rem; font-weight:900; color:{renk}; line-height:1;")">%@doluluk.ToString("F0")</div>
                                                <div style="font-size:0.6rem; color:rgba(255,255,255,0.3);">kapasite</div>
                                            </div>
                                        </div>

                                        @* Kapasite progress *@
                                        <div style="background:rgba(255,255,255,0.06); border-radius:4px; height:4px; margin-bottom:12px; overflow:hidden;">
                                            <div style="@($"height:100%; width:{doluluk}%; background:{renk}; border-radius:4px; transition:width 0.4s;")"></div>
                                        </div>

                                        @* Görev rotası (zincir) — sıra: RotaGrubu → SiraNo → IslemSureDk *@
                                        <div style="display:flex; flex-direction:column; gap:0;">
                                            @{
                                                string? _oncekiRotaGrubu = null;
                                            }
                                            @for (int i = 0; i < gorevler.Count; i++)
                                            {
                                                var g = gorevler[i];
                                                bool sonGorev = i == gorevler.Count - 1;
                                                double gorevOran = kapasite > 0 ? g.IslemSureDk * 100.0 / kapasite : 0;

                                                @* RotaGrubu bölüm ayırıcı *@
                                                @if (!string.IsNullOrEmpty(g.RotaGrubu) && g.RotaGrubu != _oncekiRotaGrubu)
                                                {
                                                    <div style="display:flex; align-items:center; gap:6px; margin:@(i == 0 ? "0" : "8px") 0 4px; padding-left:26px;">
                                                        <div style="flex:1; height:1px; background:rgba(255,255,255,0.07);"></div>
                                                        <span style="font-size:0.55rem; font-weight:900; color:rgba(255,255,255,0.3); letter-spacing:1.5px; text-transform:uppercase; padding:2px 7px; border-radius:4px; background:rgba(255,255,255,0.04);">@g.RotaGrubu</span>
                                                        <div style="flex:1; height:1px; background:rgba(255,255,255,0.07);"></div>
                                                    </div>
                                                }
                                                _oncekiRotaGrubu = g.RotaGrubu;

                                                <div style="display:flex; align-items:stretch; gap:10px;">
                                                    @* Zincir sol (dikey çizgi + nokta) *@
                                                    <div style="display:flex; flex-direction:column; align-items:center; flex-shrink:0; width:16px;">
                                                        <div style="@($"width:10px; height:10px; border-radius:50%; border:2px solid {renk}; background:{(i==0 ? renk : "transparent")}; flex-shrink:0; margin-top:2px;")"></div>
                                                        @if (!sonGorev)
                                                        {
                                                            <div style="flex:1; width:2px; background:rgba(255,255,255,0.08); margin:3px 0;"></div>
                                                        }
                                                    </div>
                                                    @* Görev kartı *@
                                                    <div style="@($"flex:1; padding:8px 10px; border-radius:8px; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.06); margin-bottom:{(sonGorev ? "0" : "6px")};")">
                                                        <div class="d-flex align-center justify-space-between">
                                                            <div style="flex:1; min-width:0;">
                                                                <div style="font-size:0.75rem; font-weight:700; color:white; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                                                    <span style="color:rgba(255,255,255,0.3); font-size:0.6rem; margin-right:5px;">@(g.SiraNo > 0 ? g.SiraNo : i+1).</span>@g.ParcaAdi
                                                                </div>
                                                                <div style="font-size:0.62rem; color:rgba(255,255,255,0.35); margin-top:2px;">@g.HeliTipi</div>
                                                            </div>
                                                            <div class="d-flex align-center gap-2" style="flex-shrink:0; margin-left:8px;">
                                                                <span style="font-size:0.62rem; padding:2px 6px; border-radius:5px; background:rgba(250,204,21,0.12); color:#FACC15; font-weight:800;">SV@(g.AtananSv)</span>
                                                                <span style="font-size:0.62rem; color:rgba(255,255,255,0.3); min-width:42px; text-align:right;">@g.IslemSureDk dk</span>
                                                            </div>
                                                        </div>
                                                        @* Görev süre bandı *@
                                                        <div style="background:rgba(255,255,255,0.04); border-radius:3px; height:3px; margin-top:6px; overflow:hidden;">
                                                            <div style="@($"height:100%; width:{gorevOran.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)}%; background:{renk}; opacity:0.6; border-radius:3px;")"></div>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                @* ── Footer butonları ─────────────────────────────────── *@
                <div class="d-flex gap-3 mt-4" style="flex-shrink:0; border-top:1px solid rgba(255,255,255,0.06); padding-top:16px;">
                    <MudButton Variant="Variant.Outlined" Color="Color.Default"
                               OnClick="() => _optOnizlemeAcik = false" Style="font-weight:700;">
                        İPTAL
                    </MudButton>
                    @if (_optSonuc.AtamaDetaylari.Any())
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Warning"
                                   StartIcon="@Icons.Material.Rounded.AssignmentTurnedIn"
                                   OnClick="OptimalAtamaUygulaAsync"
                                   Disabled="_optUyguluyor"
                                   Style="font-weight:900; flex:1;">
                            @if (_optUyguluyor)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Uygulanıyor...</span>
                            }
                            else
                            {
                                <span>TÜMÜNÜ UYGULA (@_optSonuc.AtananGorev ATAMA)</span>
                            }
                        </MudButton>
                    }
                </div>
            </div>
        </div>
    }

    @* --- PERSONEL SEÇİM PANELİ (tekil atama) --- *@
    @if (_secimAcik && _seciliKayit != null && !_topluAtamaModu)
    {
        <div class="py-backdrop" @onclick="PersonelSecimiKapat"></div>
        <div class="py-panel-container">
            <div class="py-panel" style="max-width: 1100px;">
                @* Başlık *@
                <div class="d-flex align-center justify-space-between mb-6">
                    <div>
                        <MudText Typo="Typo.h5" Style="font-weight:900; color:#facc15; letter-spacing:-1px;">Teknisyen Atama Operasyonu</MudText>
                        <div class="d-flex align-center gap-3 mt-1">
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text" Style="font-size:0.7rem; font-weight:700;">
                                @_seciliKayit.ParcaSablonu?.ParcaAdi
                            </MudChip>
                            <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.3);">P/N: @_seciliKayit.ParcaSablonu?.ParcaPN</MudText>
                            <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.3);">·</MudText>
                            <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.3);">@_seciliKayit.BakimPlani?.SeriNo</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text" Style="font-size:0.65rem; font-weight:700;">
                                @(_seciliKayit.ParcaSablonu?.IslemSure ?? 60) dk
                            </MudChip>
                        </div>
                    </div>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="PersonelSecimiKapat" Size="Size.Medium" Style="color:rgba(255,255,255,0.3);" />
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 28px;">
                    @* SOL: PERSONEL LİSTESİ *@
                    <div>
                        <MudTextField @bind-Value="_personelArama" Placeholder="İsim veya sicil no ile ara..."
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4"
                                      Style="background: rgba(255,255,255,0.02);" />

                        @{
                            var puanlar = PersonelPuaniListesi();
                            var uygunSayisi = puanlar.Count(x => x.UygunMu);
                        }
                        <div class="d-flex justify-space-between mb-3">
                            <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.3); font-weight:700;">
                                @uygunSayisi / @puanlar.Count kişi uygun
                            </MudText>
                            <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.2);">UYUM PUANINA GÖRE</MudText>
                        </div>

                        <div style="max-height: 500px; overflow-y: auto; padding-right: 6px;">
                            @if (!puanlar.Any())
                            {
                                <div class="text-center pa-10" style="opacity: 0.3;">
                                    <MudIcon Icon="@Icons.Material.Filled.PersonOff" Size="Size.Large" />
                                    <MudText Typo="Typo.body2" Class="mt-2">Personel bulunamadı.</MudText>
                                </div>
                            }
                            @foreach (var pp in puanlar)
                            {
                                var aktifIs = GetPersonelAktifIsSayisi(pp.Personel.Id);
                                var isActive = pp.Personel.Id == _seciliOnIzlemePersonelId;
                                <div class="p-secim-item @(isActive ? "p-secim-item-active" : "") @(!pp.UygunMu ? "p-secim-item-disabled" : "")"
                                     @onclick="@(() => { _seciliOnIzlemePersonelId = pp.Personel.Id; })">
                                    <MudAvatar Size="Size.Medium" Color="@(pp.UygunMu ? GetPersonelAvatarColor(aktifIs) : Color.Default)"
                                               Class="mr-3" Style="@($"font-weight:800; opacity: {(pp.UygunMu ? "1" : "0.4")};")">
                                        @(pp.Personel.Ad.Length > 0 ? pp.Personel.Ad[0] : '?')
                                    </MudAvatar>
                                    <div class="flex-1">
                                        <div class="d-flex align-center gap-2">
                                            <MudText Typo="Typo.body2" Style="@($"font-weight:800; color: {(pp.UygunMu ? "inherit" : "rgba(255,255,255,0.3)")}")">
                                                @pp.Personel.AdSoyad
                                            </MudText>
                                            @if (pp.YetkinlikSeviyesi > 0)
                                            {
                                                <span style="font-size:0.6rem; font-weight:900; padding: 1px 5px; border-radius:4px;
                                                    background: @(pp.YetkinlikSeviyesi >= 4 ? "rgba(34,197,94,0.15)" : pp.YetkinlikSeviyesi == 3 ? "rgba(59,130,246,0.15)" : "rgba(250,204,21,0.15)");
                                                    color: @(pp.YetkinlikSeviyesi >= 4 ? "#4ade80" : pp.YetkinlikSeviyesi == 3 ? "#60a5fa" : "#facc15");">
                                                    SV@pp.YetkinlikSeviyesi
                                                </span>
                                            }
                                        </div>
                                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.35); font-size:0.65rem;">
                                            @pp.Personel.Unvan · @aktifIs aktif iş
                                            @if (!pp.UygunMu && !string.IsNullOrEmpty(pp.AtanamaSebebi))
                                            {
                                                <span style="color:#ef4444; margin-left:6px;">· @pp.AtanamaSebebi</span>
                                            }
                                        </MudText>
                                    </div>
                                    <div class="text-right" style="min-width:48px;">
                                        @if (pp.UygunMu)
                                        {
                                            <div style="font-weight:900; font-size:0.9rem; color: @(pp.UyumPuani >= 80 ? "#4ade80" : pp.UyumPuani >= 50 ? "#facc15" : "#60a5fa");">
                                                @pp.UyumPuani
                                            </div>
                                            <div style="font-size:0.55rem; color:rgba(255,255,255,0.2);">PUAN</div>
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Block" Size="Size.Small" Style="color:rgba(255,255,255,0.2);" />
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    @* SAĞ: DETAY KARTI *@
                    <div>
                        @{
                            var secilenPuani = SecilenPuani;
                        }
                        @if (secilenPuani != null)
                        {
                            var p = secilenPuani.Personel;
                            var bugun = DateTime.UtcNow.Date;
                            var izinde = p.IzinBaslangic.HasValue && p.IzinBitis.HasValue
                                && bugun >= p.IzinBaslangic.Value.Date && bugun <= p.IzinBitis.Value.Date;
                            var parcaPN = _seciliKayit.ParcaSablonu?.ParcaPN ?? "";
                            var tümYetkinlikler = _yetkinliklerBySicil.GetValueOrDefault(p.SicilNo ?? "", new());
                            var gorevYetkinligi = tümYetkinlikler.FirstOrDefault(y => y.ParcaPN == parcaPN);
                            var mevcutKap = _kapasiteHaritasi.GetValueOrDefault(p.Id);
                            var aktifIs = GetPersonelAktifIsSayisi(p.Id);
                            var kalanSaat = NetVardiyaSuresi - mevcutKap;
                            var gorevSure = (_seciliKayit.ParcaSablonu?.IslemSure ?? 60) / 60.0;
                            var baslatilabilir = secilenPuani.UygunMu;

                            <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 24px; padding: 28px; height: 100%; display: flex; flex-direction: column; gap: 20px;">
                                @* Profil başlığı *@
                                <div class="d-flex align-center gap-4">
                                    <div class="py-avatar-large" style="background: @(secilenPuani.UygunMu ? "var(--gold)" : "rgba(255,255,255,0.1)");">
                                        @(p.Ad.Length > 0 ? p.Ad[0] : '?')
                                    </div>
                                    <div class="flex-1">
                                        <MudText Typo="Typo.h6" Style="font-weight:900; line-height:1.2;">@p.AdSoyad</MudText>
                                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.4);">@p.Unvan</MudText>
                                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.3);">Sicil: @p.SicilNo · @p.CalistigiYer</MudText>
                                    </div>
                                    @if (secilenPuani.UygunMu)
                                    {
                                        <div style="text-align:center; background: rgba(34,197,94,0.08); border: 1px solid rgba(34,197,94,0.2); border-radius:12px; padding: 8px 12px;">
                                            <div style="font-size:1.4rem; font-weight:900; color:#4ade80;">@secilenPuani.UyumPuani</div>
                                            <div style="font-size:0.55rem; color:rgba(74,222,128,0.6); font-weight:700;">UYUM PUANI</div>
                                        </div>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined" Style="font-size:0.65rem; font-weight:800;">UYGUN DEĞİL</MudChip>
                                    }
                                </div>

                                @* Durum satırları *@
                                <div style="display:flex; flex-direction:column; gap:8px;">
                                    @* İzin durumu *@
                                    <div class="detail-satir">
                                        <MudIcon Icon="@(izinde ? Icons.Material.Filled.BeachAccess : Icons.Material.Filled.Work)" Size="Size.Small"
                                                 Style="@($"color: {(izinde ? "#ef4444" : "#4ade80")}")" Class="mr-3"/>
                                        <MudText Typo="Typo.body2" Style="font-weight:700;">Durum</MudText>
                                        <div class="flex-1"></div>
                                        @if (izinde)
                                        {
                                            <span style="font-size:0.72rem; font-weight:700; color:#ef4444;">İZİNDE (@p.IzinBaslangic!.Value.ToString("dd.MM") – @p.IzinBitis!.Value.ToString("dd.MM"))</span>
                                        }
                                        else
                                        {
                                            <span style="font-size:0.72rem; font-weight:700; color:#4ade80;">AKTİF — MÜSAIT</span>
                                        }
                                    </div>

                                    @* Aktif iş yükü *@
                                    <div class="detail-satir">
                                        <MudIcon Icon="@Icons.Material.Filled.Assignment" Size="Size.Small" Style="color:#60a5fa;" Class="mr-3"/>
                                        <MudText Typo="Typo.body2" Style="font-weight:700;">Aktif İş Yükü</MudText>
                                        <div class="flex-1"></div>
                                        <span style="font-size:0.72rem; font-weight:700; color:@GetIsYukuRengi(aktifIs);">
                                            @aktifIs iş / @mevcutKap.ToString("F1") saat dolu
                                        </span>
                                    </div>

                                    @* Kalan kapasite *@
                                    <div class="detail-satir">
                                        <MudIcon Icon="@Icons.Material.Filled.Timer" Size="Size.Small" Style="color:#a78bfa;" Class="mr-3"/>
                                        <MudText Typo="Typo.body2" Style="font-weight:700;">Kalan Kapasite</MudText>
                                        <div class="flex-1"></div>
                                        <span style="font-size:0.72rem; font-weight:700; color: @(kalanSaat >= gorevSure ? "#4ade80" : "#ef4444");">
                                            @kalanSaat.ToString("F1") / @NetVardiyaSuresi saat
                                        </span>
                                    </div>
                                    @{
                                        var dolulukPct = Math.Min((int)(mevcutKap / NetVardiyaSuresi * 100), 100);
                                        var gorevPct = Math.Min((int)(gorevSure / NetVardiyaSuresi * 100), 100 - dolulukPct);
                                    }
                                    <div style="background: rgba(255,255,255,0.05); border-radius: 6px; height: 6px; overflow:hidden; margin-bottom:4px;">
                                        <div style="height:100%; width:@(dolulukPct)%; background:#3b82f6; float:left;"></div>
                                        <div style="height:100%; width:@(gorevPct)%; background:rgba(250,204,21,0.6); float:left;"></div>
                                    </div>

                                    @* Bu göreve yetkinlik *@
                                    <div class="detail-satir" style="margin-top:4px;">
                                        <MudIcon Icon="@(gorevYetkinligi != null ? Icons.Material.Filled.VerifiedUser : Icons.Material.Filled.GppBad)"
                                                 Size="Size.Small" Style="@($"color: {(gorevYetkinligi != null ? "#4ade80" : "#ef4444")}")" Class="mr-3"/>
                                        <MudText Typo="Typo.body2" Style="font-weight:700;">Bu Görev İçin Sertifika</MudText>
                                        <div class="flex-1"></div>
                                        @if (gorevYetkinligi != null)
                                        {
                                            <span style="font-size:0.72rem; font-weight:700; color:#4ade80;">
                                                SV@gorevYetkinligi.YetkinlikSeviyesi
                                            </span>
                                        }
                                        else
                                        {
                                            <span style="font-size:0.72rem; font-weight:700; color:#ef4444;">SERTİFİKA YOK</span>
                                        }
                                    </div>
                                </div>

                                @* Tüm sertifikalar *@
                                @if (tümYetkinlikler.Any())
                                {
                                    <div>
                                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.3); font-weight:700; letter-spacing:0.05em;" Class="mb-2">TÜM SERTİFİKALAR (@tümYetkinlikler.Count)</MudText>
                                        <div style="display:flex; flex-wrap:wrap; gap:6px;">
                                            @foreach (var y in tümYetkinlikler.OrderByDescending(x => x.YetkinlikSeviyesi).Take(12))
                                            {
                                                <span style="font-size:0.6rem; font-weight:700; padding: 3px 8px; border-radius:6px;
                                                    background: @(y.ParcaPN == parcaPN ? "rgba(250,204,21,0.15)" : "rgba(255,255,255,0.04)");
                                                    color: @(y.ParcaPN == parcaPN ? "#facc15" : "rgba(255,255,255,0.4)");
                                                    border: 1px solid @(y.ParcaPN == parcaPN ? "rgba(250,204,21,0.3)" : "rgba(255,255,255,0.06)");">
                                                    @y.ParcaPN · Sv@y.YetkinlikSeviyesi
                                                </span>
                                            }
                                            @if (tümYetkinlikler.Count > 12)
                                            {
                                                <span style="font-size:0.6rem; color:rgba(255,255,255,0.2);">+@(tümYetkinlikler.Count - 12) daha</span>
                                            }
                                        </div>
                                    </div>
                                }

                                @* GÖREVİ BAŞLAT *@
                                <div class="mt-auto">
                                    @if (!secilenPuani.UygunMu)
                                    {
                                        <div style="background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); border-radius: 12px; padding: 12px 16px; margin-bottom: 12px;">
                                            <MudText Typo="Typo.body2" Style="color:#ef4444; font-weight:700;">
                                                ✗ @secilenPuani.AtanamaSebebi
                                            </MudText>
                                        </div>
                                    }
                                    <MudButton Variant="Variant.Filled" Color="@(baslatilabilir ? Color.Success : Color.Default)"
                                               FullWidth="true" Size="Size.Large"
                                               StartIcon="@(baslatilabilir ? Icons.Material.Filled.AssignmentInd : Icons.Material.Filled.Block)"
                                               OnClick="AtaVeBaslat"
                                               Disabled="@(!baslatilabilir)"
                                               Style="height: 56px; border-radius: 16px; font-weight: 900; letter-spacing: 1px; box-shadow: 0 10px 20px -5px rgba(34,197,94,0.3);">
                                        @if (baslatilabilir)
                                        {
                                            <span>GÖREVİ BAŞLAT</span>
                                        }
                                        else
                                        {
                                            <span>ATAMA YAPILAMAZ</span>
                                        }
                                    </MudButton>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex flex-column align-center justify-center" style="height:100%; opacity:0.2;">
                                <MudIcon Icon="@Icons.Material.Filled.TouchApp" Size="Size.Large" Style="font-size:4rem;" />
                                <MudText Typo="Typo.body1" Class="mt-4">Önizleme için soldan bir teknisyen seçin.</MudText>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @* --- TAMAMLAMA DİYALOGU --- *@
    @if (_tamamlaDialogAcik && _tamamlanacakKayit != null)
    {
        var hazirlik   = _tamamlanacakKayit.ParcaSablonu?.HazirlikSuresi ?? 15;
        var islemSure  = _tamamlanacakKayit.ParcaSablonu?.IslemSure ?? 60;
        var toplamHedef = hazirlik + islemSure;
        var progressPct = toplamHedef > 0 ? Math.Min((double)_netSureDk / toplamHedef * 100, 100) : 0;
        var asimDk      = Math.Max(0, _netSureDk - toplamHedef);

        <div class="py-backdrop"></div>
        <div class="py-panel-container">
            <div class="py-panel" style="max-width: 480px;">

                @* Başlık *@
                <div class="d-flex align-center justify-space-between mb-4">
                    <div>
                        <MudText Typo="Typo.h6" Style="font-weight:900; color:#4ade80;">İş Tamamlandı</MudText>
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.4);">
                            @_tamamlanacakKayit.ParcaSablonu?.ParcaAdi · @_tamamlanacakKayit.BakimPlani?.SeriNo
                        </MudText>
                    </div>
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   OnClick="DialogKapat"
                                   Style="color:rgba(255,255,255,0.3);" />
                </div>

                @* Bilgi satırları *@
                <div style="background:rgba(255,255,255,0.03); border-radius:14px; padding:14px 18px; margin-bottom:16px; display:flex; flex-direction:column; gap:8px;">
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.4);">Hazırlık + İşlem</MudText>
                        <MudText Typo="Typo.caption" Style="font-weight:700;">@hazirlik + @islemSure = <span style="color:#facc15;">@toplamHedef dk</span></MudText>
                    </div>
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.4);">Başlangıç</MudText>
                        <MudText Typo="Typo.caption" Style="font-weight:700;">@_tamamlanacakKayit.IslemTarihi.ToLocalTime().ToString("dd.MM HH:mm")</MudText>
                    </div>
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.4);">Atanan personel</MudText>
                        <MudText Typo="Typo.caption" Style="font-weight:700;">@(_tamamlanacakKayit.AtananPersonel?.AdSoyad ?? "—")</MudText>
                    </div>
                </div>

                @* Mola bandı *@
                @if (_molada)
                {
                    <div style="background:rgba(250,204,21,0.1); border:1px solid rgba(250,204,21,0.3); border-radius:10px; padding:10px 14px; margin-bottom:12px; display:flex; align-items:center; gap:10px;">
                        <span style="font-size:1.1rem;">🟡</span>
                        <div>
                            <div style="font-weight:800; font-size:0.82rem; color:#facc15;">@_molaAdi — SAYAÇ DURAKLATILDI</div>
                            <div style="font-size:0.7rem; color:rgba(255,255,255,0.4);">@_molaKalanDk dk sonra devam edecek</div>
                        </div>
                    </div>
                }

                @* Otomatik tamamlama countdown *@
                @if (_countdownAktif)
                {
                    <div style="background:rgba(74,222,128,0.08); border:1px solid rgba(74,222,128,0.3); border-radius:14px; padding:18px; margin-bottom:12px; text-align:center;">
                        <div style="font-size:0.85rem; font-weight:700; color:#4ade80; margin-bottom:8px;">✅ Görev süresi doldu!</div>
                        <div style="font-size:0.75rem; color:rgba(255,255,255,0.5); margin-bottom:12px;">@_countdownSaniye saniye içinde otomatik kaydediliyor...</div>
                        <div style="background:rgba(255,255,255,0.06); border-radius:6px; height:6px; overflow:hidden; margin-bottom:14px;">
                            <div style="height:100%; border-radius:6px; background:#4ade80; width:@((_countdownSaniye * 10).ToString())%; transition:width 0.9s linear;"></div>
                        </div>
                        <div class="d-flex gap-2 justify-center">
                            <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                                       OnClick="DevamEt"
                                       Style="border-radius:10px; font-weight:800; font-size:0.78rem;">
                                ⏱ DEVAM ET — Gecikme var
                            </MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Success"
                                       OnClick="IsBitirOnayla"
                                       Style="border-radius:10px; font-weight:800; font-size:0.78rem;">
                                HEMEN TAMAMLA
                            </MudButton>
                        </div>
                    </div>
                }
                else
                {
                    @* FAZ banner *@
                    <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:10px; padding:8px 14px; margin-bottom:12px; display:flex; align-items:center; justify-content:space-between;">
                        <span style="font-size:0.78rem; font-weight:800; color:@_fazRenk;">
                            @(_fazAdi == "SETUP" ? "🔧" : _fazAdi == "İŞLEM" ? "⚙️" : "⚠️") FAZ: @_fazAdi
                        </span>
                        @if (_mesaiFazinda && asimDk > 0)
                        {
                            <span style="font-size:0.72rem; color:#f97316; font-weight:700;">+@asimDk dk aşım</span>
                        }
                    </div>

                    @* Progress bar *@
                    <div style="background:rgba(255,255,255,0.06); border-radius:6px; height:8px; overflow:hidden; margin-bottom:6px; position:relative;">
                        <div style="height:100%; border-radius:6px; background:@_fazRenk; width:@(progressPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%; transition:width 0.8s ease; float:left;"></div>
                        @if (_mesaiFazinda && asimDk > 0)
                        {
                            var asimPct = Math.Min((double)asimDk / toplamHedef * 100, 20);
                            <div style="height:100%; border-radius:6px; background:#f97316; width:@(asimPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%; float:left;"></div>
                        }
                    </div>
                    <div style="display:flex; justify-content:space-between; margin-bottom:16px;">
                        <span style="font-size:0.65rem; color:rgba(255,255,255,0.3);">0</span>
                        <span style="font-size:0.65rem; color:rgba(255,255,255,0.3);">@toplamHedef dk</span>
                    </div>

                    @* Büyük sayaç *@
                    <div style="text-align:center; padding:16px 0 20px;">
                        <div style="font-size:3rem; font-weight:900; color:@_fazRenk; line-height:1; font-variant-numeric:tabular-nums;">
                            @_netSureDk <span style="font-size:1.2rem; opacity:0.6;">DK</span>
                        </div>
                        <div style="font-size:0.7rem; color:rgba(255,255,255,0.3); margin-top:4px; font-weight:600; letter-spacing:0.05em;">
                            @(_molada ? "MOLA — DURAKLATILDI" : "NET ÇALIŞMA SÜRESİ")
                        </div>
                    </div>

                    @* Manuel giriş toggle *@
                    <div style="margin-bottom:16px;">
                        <MudButton Variant="Variant.Text" Color="Color.Default"
                                   OnClick="@(() => _manuelGiris = !_manuelGiris)"
                                   Style="font-size:0.72rem; color:rgba(255,255,255,0.3); padding:4px 8px;">
                            @(_manuelGiris ? "▲ Sayacı kullan" : "▼ Süreyi manuel gir")
                        </MudButton>
                        @if (_manuelGiris)
                        {
                            <MudNumericField T="int" @bind-Value="_gercekSureDk"
                                             Label="Gerçek Süre (dakika)"
                                             Variant="Variant.Outlined"
                                             Min="1" Max="1440"
                                             FullWidth="true"
                                             Class="mt-2"
                                             AdornmentIcon="@Icons.Material.Filled.Timer"
                                             Adornment="Adornment.Start" />
                        }
                    </div>

                    @* Footer butonlar *@
                    <div class="d-flex gap-3 justify-end">
                        <MudButton Variant="Variant.Outlined" OnClick="DialogKapat"
                                   Style="border-radius:10px;">İptal</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.CheckCircle"
                                   OnClick="IsBitirOnayla"
                                   Style="border-radius:10px; font-weight:800;">
                            Tamamla ve Kaydet
                        </MudButton>
                    </div>
                }
            </div>
        </div>
    }

    @* --- ONAY DİYALOGU --- *@
    @if (_onayDialogAcik)
    {
        var risk = RiskSkoru();
        var atananlar = _planAtamalari.Where(kv => kv.Value.HasValue).ToList();
        var atanmayanlar = _islerBekleyen.Where(x => !_planAtamalari.TryGetValue(x.Id, out var v) || !v.HasValue).ToList();

        <div class="py-backdrop" @onclick="@(() => _onayDialogAcik = false)"></div>
        <div class="py-panel-container">
            <div class="py-panel" style="max-width: 640px;">
                <div class="d-flex align-center justify-space-between mb-4">
                    <MudText Typo="Typo.h5" Style="font-weight:900; color:var(--gold);">Plan Özeti</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _onayDialogAcik = false)" Style="color:rgba(255,255,255,0.3);" />
                </div>

                @* Risk skoru *@
                <div class="onay-risk-bar mb-4" style="background: @(risk == 0 ? "rgba(34,197,94,0.1)" : risk < 40 ? "rgba(250,204,21,0.1)" : "rgba(239,68,68,0.1)"); border: 1px solid @(risk == 0 ? "rgba(34,197,94,0.3)" : risk < 40 ? "rgba(250,204,21,0.3)" : "rgba(239,68,68,0.3)"); border-radius: 12px; padding: 12px 16px;">
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@(risk == 0 ? Icons.Material.Filled.Shield : Icons.Material.Filled.Warning)"
                                 Style="@($"color: {(risk == 0 ? "#4ade80" : risk < 40 ? "#facc15" : "#ef4444")}")" />
                        <MudText Typo="Typo.body2" Style="font-weight: 700;">
                            Risk Skoru: @risk — @(risk == 0 ? "Düşük Risk" : risk < 40 ? "Orta Risk" : "Yüksek Risk")
                        </MudText>
                        @if (_egitimModu)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled" Style="font-size: 0.65rem;">EĞİTİM MODU</MudChip>
                        }
                    </div>
                </div>

                @* Atamalar listesi *@
                @if (atananlar.Any())
                {
                    <MudText Typo="Typo.subtitle2" Class="mb-2" Style="color: #4ade80; font-weight: 700;">✓ Atanacak İşler (@atananlar.Count)</MudText>
                    <div style="max-height: 250px; overflow-y: auto; margin-bottom: 16px;">
                        @foreach (var kv in atananlar)
                        {
                            var is_ = _islerBekleyen.FirstOrDefault(x => x.Id == kv.Key);
                            var personel = _personeller.FirstOrDefault(p => p.Id == kv.Value!.Value);
                            var yetk = _yetkinlikler.FirstOrDefault(y => y.SicilNo == personel?.SicilNo && y.ParcaPN == is_?.ParcaSablonu?.ParcaPN);

                            <div style="padding: 8px 12px; background: rgba(255,255,255,0.03); border-radius: 8px; margin-bottom: 6px; border-left: 3px solid #22c55e;">
                                <div style="font-weight: 700; font-size: 0.82rem;">@is_?.ParcaSablonu?.ParcaAdi</div>
                                <div style="color: rgba(255,255,255,0.5); font-size: 0.72rem;">
                                    → @personel?.AdSoyad (Sv@(yetk?.YetkinlikSeviyesi ?? 0))
                                </div>
                            </div>
                        }
                    </div>
                }

                @* Atanmayanlar *@
                @if (atanmayanlar.Any())
                {
                    <div style="padding: 12px; background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); border-radius: 10px; margin-bottom: 16px;">
                        <MudText Typo="Typo.body2" Style="font-weight: 700; color: #ef4444; margin-bottom: 6px;">⚠ Atanmayan İşler (@atanmayanlar.Count)</MudText>
                        @foreach (var is_ in atanmayanlar)
                        {
                            <div style="font-size: 0.72rem; color: rgba(255,255,255,0.5); margin-bottom: 2px;">· @is_.ParcaSablonu?.ParcaAdi (@is_.BakimPlani?.SeriNo)</div>
                        }
                    </div>
                }

                <div class="d-flex gap-3 justify-end mt-4">
                    <MudButton Variant="Variant.Outlined" OnClick="@(() => _onayDialogAcik = false)" Style="border-radius: 10px;">İptal</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="PlanOnayla"
                               StartIcon="@Icons.Material.Filled.CheckCircle" Style="border-radius: 10px; font-weight: 800;">
                        Onayla ve Uygula (@atananlar.Count iş)
                    </MudButton>
                </div>
            </div>
        </div>
    }
</MudContainer>

