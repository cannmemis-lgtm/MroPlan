    // ── Optimal Atama ──────────────────────────────────────────────────────────

    private async Task OptimalAtamaAcAsync()
    {
        _optYukleniyor = true;
        StateHasChanged();

        // Seçili atölye kodu — sadece bu atölyenin personeli ve görevleri kullanılır
        var atolye = _atolyeler.FirstOrDefault(a => a.Id == _seciliAtolyeId);

        _optSonuc = await OptimizasyonService.PersonelAtamaOptimizeEtAsync(0, atolye?.AtolyeKodu);

        _optYukleniyor = false;
        _optOnizlemeAcik = true;
    }

    private async Task OptimalAtamaUygulaAsync()
    {
        if (_optSonuc == null || !_optSonuc.AtamaDetaylari.Any()) return;

        _optUyguluyor = true;
        StateHasChanged();

        int sayac = 0;
        try
        {
            var hedefIdler = _optSonuc.AtamaDetaylari
                .Select(a => a.BakimKontrolKaydiId)
                .ToHashSet();

            // AsNoTracking yerine tracked kayıtları fresh çek — Attach çakışmasını önler
            var kayitlar = await Context.BakimKontrolKayitlari
                .Where(k => hedefIdler.Contains(k.Id))
                .ToListAsync();

            foreach (var atama in _optSonuc.AtamaDetaylari)
            {
                var kayit = kayitlar.FirstOrDefault(k => k.Id == atama.BakimKontrolKaydiId);
                if (kayit == null) continue;

                kayit.AtananPersonelId = atama.PersonelId;
                kayit.Durum            = nameof(BakimDurumu.DevamEdiyor);
                kayit.IslemTarihi      = DateTime.UtcNow;
                sayac++;
            }

            await Context.SaveChangesAsync();
            _optOnizlemeAcik = false;
            _optSonuc = null;
            Snackbar.Add($"Optimal atama tamamlandı — {sayac} iş atandı.", Severity.Success);
            await IslerYukle();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Atama hatası: " + ex.Message, Severity.Error);
        }
        finally
        {
            _optUyguluyor = false;
        }
    }

