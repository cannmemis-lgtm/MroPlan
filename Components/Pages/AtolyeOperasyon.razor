    }

    // ── Timer ──────────────────────────────────────────────────────────────────

    private void BaslatTimer()
    {
        DurdurTimer();
        _timerCts = new CancellationTokenSource();
        _ = TimerDongusuAsync(_timerCts.Token);
    }

    private void DurdurTimer()
    {
        _timerCts?.Cancel();
        _timerCts?.Dispose();
        _timerCts = null;
    }

    private async Task TimerDongusuAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                var simdi     = DateTime.Now;
                var baslangic = (_tamamlanacakKayit?.IslemTarihi ?? simdi).ToLocalTime();
                var hazirlik  = _tamamlanacakKayit?.ParcaSablonu?.HazirlikSuresi ?? 15;
                var islemSure = _tamamlanacakKayit?.ParcaSablonu?.IslemSure ?? 60;
                var toplamHedef = hazirlik + islemSure;

                // Mola kontrolü
                var simdikSaat = TimeOnly.FromDateTime(simdi);
                _molada = false; _molaAdi = ""; _molaKalanDk = 0;
                foreach (var (bas, bit, ad) in MolaTakvimi)
                {
                    if (simdikSaat >= bas && simdikSaat < bit)
                    {
                        _molada      = true;
                        _molaAdi     = ad;
                        _molaKalanDk = (int)(bit.ToTimeSpan() - simdikSaat.ToTimeSpan()).TotalMinutes + 1;
                        break;
                    }
                }

                // Net süre: geçen toplam - tamamlanmış molalar
                var toplamGecenDk = (simdi - baslangic).TotalMinutes;
                var toplamMolaDk  = HesaplaMolaDakikasi(baslangic, simdi);
                // Şu an moladaysa aktif molayı da düş
                if (_molada)
                {
                    foreach (var (bas, bit, _) in MolaTakvimi)
                    {
                        var molaBasSimdi = simdi.Date + bas.ToTimeSpan();
                        if (simdi >= molaBasSimdi && TimeOnly.FromDateTime(simdi) < bit)
                        {
                            toplamMolaDk += (simdi - molaBasSimdi).TotalMinutes;
                            break;
                        }
                    }
                }

                _netSureDk = Math.Max(0, (int)(toplamGecenDk - toplamMolaDk));
                if (!_manuelGiris) _gercekSureDk = _netSureDk;

                // Faz güncelle
                if (!_mesaiFazinda)
                {
                    if (_netSureDk < hazirlik)        { _fazAdi = "SETUP";  _fazRenk = "#facc15"; }
                    else if (_netSureDk < toplamHedef) { _fazAdi = "İŞLEM"; _fazRenk = "#3b82f6"; }
                    else if (!_countdownAktif)
                    {
                        _countdownAktif  = true;
                        _countdownSaniye = 10;
                        _ = CountdownAsync(ct);
                    }
                }

                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task CountdownAsync(CancellationToken ct)
    {
        try
        {
            while (_countdownSaniye > 0 && _countdownAktif && !ct.IsCancellationRequested)
            {
                await Task.Delay(1000, ct);
                _countdownSaniye--;
                await InvokeAsync(StateHasChanged);
            }
            if (_countdownAktif && !ct.IsCancellationRequested)
                await InvokeAsync(IsBitirOnayla);
        }
        catch (OperationCanceledException) { }
    }

    // Başlangıç–şimdi arasındaki tamamen geçmiş mola dakikalarını hesapla
    private static double HesaplaMolaDakikasi(DateTime baslangic, DateTime simdi)
    {
        double toplam = 0;
        foreach (var (bas, bit, _) in MolaTakvimi)
        {
            foreach (var gun in new[] { simdi.Date, simdi.Date.AddDays(-1) })
            {
                var mBas = gun + bas.ToTimeSpan();
                var mBit = gun + bit.ToTimeSpan();
                if (mBit <= baslangic || mBas >= simdi) continue;
                var kBas = mBas < baslangic ? baslangic : mBas;
                var kBit = mBit > simdi     ? simdi     : mBit;
                if (kBit > kBas) toplam += (kBit - kBas).TotalMinutes;
            }
        }
        return toplam;
    }

    public void Dispose() => DurdurTimer();

    private async Task IsBitirOnayla()
    {
        if (_tamamlanacakKayit == null) return;
        var item = _tamamlanacakKayit;
        DurdurTimer();
        _tamamlaDialogAcik = false;
        _countdownAktif    = false;

        try
        {
            var kayit = await Context.BakimKontrolKayitlari.FindAsync(item.Id);
            if (kayit == null) return;
            kayit.Durum            = nameof(BakimDurumu.Tamamlandi);
            kayit.TamamlanmaTarihi = DateTime.UtcNow;
            kayit.GercekSureDk     = _gercekSureDk > 0 ? _gercekSureDk : null;
            await Context.SaveChangesAsync();

            // SV yetkinlik güncelleme
            var personelId = kayit.AtananPersonelId ?? item.GelistirmePersonelId;
            if (personelId.HasValue && kayit.ParcaSablonuId > 0)
                await YetkinlikService.KartTamamlandiAsync(personelId.Value, kayit.ParcaSablonuId, kayit.Id);

            // Plan otomatik tamamlanma kontrolü
            var tumIsler = await Context.BakimKontrolKayitlari
                .Where(k => k.BakimPlaniId == kayit.BakimPlaniId)
                .ToListAsync();

            if (tumIsler.Any() && tumIsler.All(k => k.Durum == nameof(BakimDurumu.Tamamlandi)))
            {
                var plan = await Context.BakimPlanlari.FindAsync(kayit.BakimPlaniId);
                if (plan != null)
                {
                    plan.GenelDurum  = nameof(BakimDurumu.Tamamlandi);
                    plan.TeslimTarihi = DateTime.UtcNow;
                    await Context.SaveChangesAsync();
                    Snackbar.Add($"Tüm işler tamamlandı! {plan.SeriNo} bakım planı kapatıldı.", Severity.Success);
                }
            }
            else
            {
                Snackbar.Add($"İşlem tamamlandı. Gerçek süre: {_gercekSureDk} dk kaydedildi.", Severity.Success);
            }

            await IslerYukle();
        }
        catch (Exception ex) { Snackbar.Add("Hata: " + ex.Message, Severity.Error); }
    }

