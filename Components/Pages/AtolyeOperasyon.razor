@code {
    private const double NetVardiyaSuresi = 8.0;

    private List<BakimGrubu> _atolyeler = new();
    private List<BakimKontrolKaydi> _tumIsler = new();
    private List<Personel> _personeller = new();
    private List<Yetkinlik> _yetkinlikler = new();
    private int _seciliAtolyeId;

    // Tekil atama
    private bool _secimAcik;
    private BakimKontrolKaydi? _seciliKayit;
    private string _personelArama = string.Empty;
    private int _seciliOnIzlemePersonelId = 0;
    private List<PersonelPuani> _tekAtamaPuanlari = new();

    // Toplu atama
    private bool _topluAtamaModu;
    private bool _egitimModu;
    private bool _onayDialogAcik;

    // Vardiya planı
    private bool _vardiyaModu;
    private Dictionary<int, List<BakimKontrolKaydi>> _vardiyaAtamalari = new();
    private Dictionary<int, int?> _planAtamalari = new();
    private Dictionary<int, double> _kapasiteHaritasi = new();
    private Dictionary<int, double> _planKapasitesi = new();


    // İş tamamlama dialog
    private bool _tamamlaDialogAcik;
    private BakimKontrolKaydi? _tamamlanacakKayit;
    private int _gercekSureDk;

    private record PersonelPuani(Personel Personel, int UyumPuani, bool UygunMu, string? AtanamaSebebi, int YetkinlikSeviyesi);

    private List<BakimKontrolKaydi> _filtrelenmisIsler => _tumIsler
        .Where(x => x.ParcaSablonu?.BakimGrubuId == _seciliAtolyeId)
        .ToList();

    private List<BakimKontrolKaydi> _islerBekleyen => _filtrelenmisIsler
        .Where(x => x.Durum.Equals(nameof(BakimDurumu.Beklemede), StringComparison.OrdinalIgnoreCase)).ToList();
    private List<BakimKontrolKaydi> _islerDevamEden => _filtrelenmisIsler
        .Where(x => x.Durum.Equals(nameof(BakimDurumu.DevamEdiyor), StringComparison.OrdinalIgnoreCase)).ToList();
    private List<BakimKontrolKaydi> _islerBiten => _filtrelenmisIsler
        .Where(x => x.Durum.Equals(nameof(BakimDurumu.Tamamlandi), StringComparison.OrdinalIgnoreCase)).ToList();

    protected override async Task OnInitializedAsync() => await VerileriYukle();

    private async Task VerileriYukle()
    {
        _atolyeler = await Context.BakimGruplari.ToListAsync();
        _tumIsler = await Context.BakimKontrolKayitlari
            .Include(x => x.BakimPlani)
            .Include(x => x.ParcaSablonu)
                .ThenInclude(p => p!.BakimGrubu)
            .Include(x => x.AtananPersonel)
            .Include(x => x.SupervisorPersonel)
            .ToListAsync();
        _personeller = await Context.Personeller.ToListAsync();
        _yetkinlikler = await Context.Yetkinlikler.ToListAsync();

        _kapasiteHaritasi = _tumIsler
            .Where(x => x.Durum == nameof(BakimDurumu.DevamEdiyor) && x.AtananPersonelId.HasValue)
            .GroupBy(x => x.AtananPersonelId!.Value)
            .ToDictionary(g => g.Key, g => g.Sum(x => (x.ParcaSablonu?.IslemSure ?? 60) / 60.0));
    }

    // --- Atölye kart yardımcıları ---

    private int GetPersonelSayisi(string? atolyeKodu) =>
        _personeller.Count(x => x.AtolyeKodu == atolyeKodu);

    private int GetIsSayisi(int atolyeId) =>
        _tumIsler.Count(x => x.ParcaSablonu?.BakimGrubuId == atolyeId && x.Durum != nameof(BakimDurumu.Tamamlandi));

    private int GetPersonelAktifIsSayisi(int personelId) =>
        _tumIsler.Count(x => x.AtananPersonelId == personelId && x.Durum == nameof(BakimDurumu.DevamEdiyor));

    private string GetIsYukuRengi(int aktifIs) => aktifIs switch { 0 => "#4ade80", 1 => "#facc15", _ => "#ef4444" };

    private Color GetPersonelAvatarColor(int aktifIs) => aktifIs switch { 0 => Color.Success, 1 => Color.Warning, _ => Color.Error };

    private string GetAtolyeClass(int id, int doluluk)
    {
        var cls = id == _seciliAtolyeId ? "atolye-card atolye-card-active" : "atolye-card";
        if (doluluk > 80) cls += " atolye-card-urgent";
        return cls;
    }

    private string GetAtolyeIcon(string grupAdi)
    {
        var n = grupAdi.ToLower();
        if (n.Contains("avionik") || n.Contains("aviyonik")) return Icons.Material.Filled.Memory;
        if (n.Contains("boya")) return Icons.Material.Filled.Brush;
        if (n.Contains("elektrik")) return Icons.Material.Filled.Bolt;
        if (n.Contains("gövde") || n.Contains("govde")) return Icons.Material.Filled.Handyman;
        if (n.Contains("hidrolik")) return Icons.Material.Filled.WaterDrop;
        if (n.Contains("motor")) return Icons.Material.Filled.SettingsSuggest;
        if (n.Contains("pal") || n.Contains("rotor")) return Icons.Material.Filled.Air;
        if (n.Contains("tahribatsız") || n.Contains("ndt")) return Icons.Material.Filled.Radar;
        if (n.Contains("transmisyon")) return Icons.Material.Filled.Settings;
        if (n.Contains("uçuş") || n.Contains("ucus")) return Icons.Material.Filled.Gamepad;
        return Icons.Material.Filled.PrecisionManufacturing;
    }

    private void AtolyeSec(BakimGrubu a)
    {
        _seciliAtolyeId = a.Id;
        _topluAtamaModu = false;
        _vardiyaModu = false;
        _planAtamalari.Clear();
        _planKapasitesi.Clear();

        _vardiyaAtamalari.Clear();
    }

    // --- Vardiya Planı ---

    private void VardiyaPlaniniOlustur()
    {
        _vardiyaModu = true;
        _topluAtamaModu = false;
        _egitimModu = false;
        VardiyaYenidenDagit();
    }

    private void VardiyaYenidenDagit()
    {
        _vardiyaAtamalari.Clear();

        // Atölyedeki tüm aktif personeli başlangıçta boş listelerle doldur
        var atolye = _atolyeler.FirstOrDefault(a => a.Id == _seciliAtolyeId);
        var atSolPersoneller = _personeller
            .Where(p => p.Durum == "Aktif" && p.AtolyeKodu == atolye?.AtolyeKodu)
            .OrderBy(p => _kapasiteHaritasi.GetValueOrDefault(p.Id))  // en az yüklü önce
            .ToList();

        foreach (var p in atSolPersoneller)
            _vardiyaAtamalari[p.Id] = new List<BakimKontrolKaydi>();

        // Kapasite takip (mevcut + planlanan)
        var kapasiteTakip = atSolPersoneller
            .ToDictionary(p => p.Id, p => _kapasiteHaritasi.GetValueOrDefault(p.Id));

        // İşleri aciliyete göre sırala
        var siraliIsler = _islerBekleyen.OrderByDescending(x => AciliyetPuaniHesapla(x)).ToList();

        foreach (var is_ in siraliIsler)
        {
            var parcaPN = is_.ParcaSablonu?.ParcaPN ?? "";
            var gereklSure = ((is_.ParcaSablonu?.IslemSure ?? 60) + (is_.ParcaSablonu?.HazirlikSuresi ?? 15)) / 60.0;

            // Uygun personeli puana göre sırala, AMA en az yüklü olan öne geçsin (yayma)
            var uygunlar = atSolPersoneller
                .Where(p =>
                {
                    if (p.Durum != "Aktif") return false;
                    var bugun = DateTime.UtcNow.Date;
                    if (p.IzinBaslangic.HasValue && p.IzinBitis.HasValue
                        && bugun >= p.IzinBaslangic.Value.Date && bugun <= p.IzinBitis.Value.Date)
                        return false;
                    var yetk = _yetkinlikler.FirstOrDefault(y => y.SicilNo == p.SicilNo && y.ParcaPN == parcaPN);
                    if (yetk == null) return false;
                    return (kapasiteTakip[p.Id] + gereklSure) <= NetVardiyaSuresi;
                })
                .OrderBy(p => kapasiteTakip[p.Id])           // en boş önce → yayma
                .ThenByDescending(p =>
                {
                    var y = _yetkinlikler.FirstOrDefault(x => x.SicilNo == p.SicilNo && x.ParcaPN == parcaPN);
                    return y?.YetkinlikSeviyesi ?? 0;
                })
                .ToList();

            if (!uygunlar.Any()) continue;

            var secilenP = uygunlar.First();
            _vardiyaAtamalari[secilenP.Id].Add(is_);
            kapasiteTakip[secilenP.Id] += gereklSure;
        }
    }

    private void VardiyaIsKaldir(int personelId, BakimKontrolKaydi is_)
    {
        if (_vardiyaAtamalari.TryGetValue(personelId, out var liste))
            liste.Remove(is_);
    }

    private void VardiyaModundanCik()
    {
        _vardiyaModu = false;
        _vardiyaAtamalari.Clear();
    }

    private async Task VardiyaPlaniniOnayla()
    {
        int sayac = 0;
        foreach (var (personelId, isler) in _vardiyaAtamalari)
        {
            foreach (var is_ in isler)
            {
                var kayit = _tumIsler.FirstOrDefault(x => x.Id == is_.Id);
                if (kayit == null) continue;
                kayit.AtananPersonelId = personelId;
                kayit.Durum = nameof(BakimDurumu.DevamEdiyor);
                kayit.IslemTarihi = await ZamanServisi.TahminiBitisHesaplaAsync(DateTime.UtcNow, 0);
                kayit.EgitimModu = _egitimModu;
                sayac++;
            }
        }

        try
        {
            await Context.SaveChangesAsync();
            Snackbar.Add($"Vardiya planı uygulandı — {sayac} iş atandı.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Kayıt hatası: " + ex.Message, Severity.Error);
            return;
        }

        VardiyaModundanCik();
        await VerileriYukle();
    }

    private string AciliyetRenkKod(int puan) => puan >= 70 ? "#ef4444" : puan >= 40 ? "#facc15" : "#60a5fa";

    // --- Tekil atama ---

    private List<PersonelPuani> PersonelPuaniListesi()
    {
        return _tekAtamaPuanlari
            .Where(x => string.IsNullOrWhiteSpace(_personelArama)
                || x.Personel.AdSoyad.Contains(_personelArama, StringComparison.OrdinalIgnoreCase)
                || x.Personel.SicilNo.Contains(_personelArama, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(x => x.UygunMu)
            .ThenByDescending(x => x.UyumPuani)
            .ThenBy(x => x.Personel.AdSoyad)
            .ToList();
    }

    private void PersonelSecimiAc(BakimKontrolKaydi item)
    {
        _seciliKayit = item;
        _personelArama = string.Empty;
        _seciliOnIzlemePersonelId = 0;
        _tekAtamaPuanlari = _seciliKayit != null ? UygunPersonelListesi(_seciliKayit) : new();
        _secimAcik = true;
    }

    private void PersonelSecimiKapat() => _secimAcik = false;

    private PersonelPuani? SecilenPuani =>
        _seciliOnIzlemePersonelId > 0
            ? _tekAtamaPuanlari.FirstOrDefault(x => x.Personel.Id == _seciliOnIzlemePersonelId)
            : null;

    private async Task AtaVeBaslat()
    {
        if (_seciliKayit == null || SecilenPuani == null) return;
        var p = SecilenPuani.Personel;
        try
        {
            var entry = Context.Entry(_seciliKayit);
            if (entry.State == EntityState.Detached) Context.Attach(_seciliKayit);
            _seciliKayit.AtananPersonelId = p.Id;
            _seciliKayit.Durum = nameof(BakimDurumu.DevamEdiyor);
            _seciliKayit.IslemTarihi = DateTime.UtcNow;
            await Context.SaveChangesAsync();
            Snackbar.Add($"{p.AdSoyad} göreve atandı.", Severity.Success);
            PersonelSecimiKapat();
            await VerileriYukle();
        }
        catch (Exception ex) { Snackbar.Add("Atama hatası: " + ex.Message, Severity.Error); }
    }

    private void IsBitir(BakimKontrolKaydi item)
    {
        _tamamlanacakKayit = item;
        var gecenDk = (int)(DateTime.UtcNow - item.IslemTarihi).TotalMinutes;
        // Makul aralık: 1 dk – 1440 dk (24 saat). Dışındaysa tahmini süreyi kullan.
        _gercekSureDk = gecenDk >= 1 && gecenDk <= 1440
            ? gecenDk
            : item.ParcaSablonu?.IslemSure ?? 60;
        _tamamlaDialogAcik = true;
    }

    private async Task IsBitirOnayla()
    {
        if (_tamamlanacakKayit == null) return;
        var item = _tamamlanacakKayit;
        _tamamlaDialogAcik = false;

        try
        {
            item.Durum            = nameof(BakimDurumu.Tamamlandi);
            item.TamamlanmaTarihi = DateTime.UtcNow;
            item.GercekSureDk     = _gercekSureDk > 0 ? _gercekSureDk : null;
            await Context.SaveChangesAsync();

            // SV yetkinlik güncelleme
            var personelId = item.AtananPersonelId ?? item.GelistirmePersonelId;
            if (personelId.HasValue && item.ParcaSablonuId > 0)
                await YetkinlikService.KartTamamlandiAsync(personelId.Value, item.ParcaSablonuId, item.Id);

            // Plan otomatik tamamlanma kontrolü
            var tumIsler = await Context.BakimKontrolKayitlari
                .Where(k => k.BakimPlaniId == item.BakimPlaniId)
                .ToListAsync();

            if (tumIsler.Any() && tumIsler.All(k => k.Durum == nameof(BakimDurumu.Tamamlandi)))
            {
                var plan = await Context.BakimPlanlari.FindAsync(item.BakimPlaniId);
                if (plan != null)
                {
                    plan.GenelDurum  = nameof(BakimDurumu.Tamamlandi);
                    plan.TeslimTarihi = DateTime.UtcNow;
                    await Context.SaveChangesAsync();
                    Snackbar.Add($"Tüm işler tamamlandı! {plan.SeriNo} bakım planı kapatıldı.", Severity.Success);
                }
            }
            else
            {
                Snackbar.Add($"İşlem tamamlandı. Gerçek süre: {_gercekSureDk} dk kaydedildi.", Severity.Success);
            }

            await VerileriYukle();
        }
        catch (Exception ex) { Snackbar.Add("Hata: " + ex.Message, Severity.Error); }
    }

    private async Task AtamayiKaldir(BakimKontrolKaydi item)
    {
        try
        {
            item.AtananPersonelId = null;
            item.Durum = nameof(BakimDurumu.Beklemede);
            item.IslemTarihi = DateTime.UtcNow;
            await Context.SaveChangesAsync();
            Snackbar.Add("Personel ataması kaldırıldı.", Severity.Warning);
