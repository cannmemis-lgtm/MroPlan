    // --- Vardiya Planı ---

    private void VardiyaPlaniniOlustur()
    {
        _vardiyaModu = true;
        _topluAtamaModu = false;
        _egitimModu = false;
        VardiyaYenidenDagit();
    }

    private void VardiyaYenidenDagit()
    {
        _vardiyaAtamalari.Clear();

        // Atölyedeki tüm aktif personeli başlangıçta boş listelerle doldur
        var atolye = _atolyeler.FirstOrDefault(a => a.Id == _seciliAtolyeId);
        var atSolPersoneller = _personeller
            .Where(p => p.Durum == "Aktif" && p.AtolyeKodu == atolye?.AtolyeKodu)
            .OrderBy(p => _kapasiteHaritasi.GetValueOrDefault(p.Id))  // en az yüklü önce
            .ToList();

        foreach (var p in atSolPersoneller)
            _vardiyaAtamalari[p.Id] = new List<BakimKontrolKaydi>();

        // Kapasite takip (mevcut + planlanan)
        var kapasiteTakip = atSolPersoneller
            .ToDictionary(p => p.Id, p => _kapasiteHaritasi.GetValueOrDefault(p.Id));

        // İşleri aciliyete göre sırala
        var siraliIsler = _islerBekleyen.OrderByDescending(x => AciliyetPuaniHesapla(x)).ToList();

        foreach (var is_ in siraliIsler)
        {
            var parcaPN = is_.ParcaSablonu?.ParcaPN ?? "";
            var gereklSure = ((is_.ParcaSablonu?.IslemSure ?? 60) + (is_.ParcaSablonu?.HazirlikSuresi ?? 15)) / 60.0;

            // Uygun personeli puana göre sırala, AMA en az yüklü olan öne geçsin (yayma)
            var uygunlar = atSolPersoneller
                .Where(p =>
                {
                    if (p.Durum != "Aktif") return false;
                    var bugun = DateTime.UtcNow.Date;
                    if (p.IzinBaslangic.HasValue && p.IzinBitis.HasValue
                        && bugun >= p.IzinBaslangic.Value.Date && bugun <= p.IzinBitis.Value.Date)
                        return false;
                    var yetk = _yetkinlikler.FirstOrDefault(y => y.SicilNo == p.SicilNo && y.ParcaPN == parcaPN);
                    if (yetk == null) return false;
                    return (kapasiteTakip[p.Id] + gereklSure) <= NetVardiyaSuresi;
                })
                .OrderBy(p => kapasiteTakip[p.Id])           // en boş önce → yayma
                .ThenByDescending(p =>
                {
                    var y = _yetkinlikler.FirstOrDefault(x => x.SicilNo == p.SicilNo && x.ParcaPN == parcaPN);
                    return y?.YetkinlikSeviyesi ?? 0;
                })
                .ToList();

            if (!uygunlar.Any()) continue;

            var secilenP = uygunlar.First();
            _vardiyaAtamalari[secilenP.Id].Add(is_);
            kapasiteTakip[secilenP.Id] += gereklSure;
        }
    }

    private void VardiyaIsKaldir(int personelId, BakimKontrolKaydi is_)
    {
        if (_vardiyaAtamalari.TryGetValue(personelId, out var liste))
            liste.Remove(is_);
    }

    private void VardiyaModundanCik()
    {
        _vardiyaModu = false;
        _vardiyaAtamalari.Clear();
    }

    private async Task VardiyaPlaniniOnayla()
    {
        int sayac = 0;
        foreach (var (personelId, isler) in _vardiyaAtamalari)
        {
            foreach (var is_ in isler)
            {
                var kayit = _tumIsler.FirstOrDefault(x => x.Id == is_.Id);
                if (kayit == null) continue;
                kayit.AtananPersonelId = personelId;
                kayit.Durum = nameof(BakimDurumu.DevamEdiyor);
                kayit.IslemTarihi = await ZamanServisi.TahminiBitisHesaplaAsync(DateTime.UtcNow, 0);
                kayit.EgitimModu = _egitimModu;
                sayac++;
            }
        }

        try
        {
            await Context.SaveChangesAsync();
            Snackbar.Add($"Vardiya planı uygulandı — {sayac} iş atandı.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Kayıt hatası: " + ex.Message, Severity.Error);
            return;
        }

        VardiyaModundanCik();
        await IslerYukle();
    }

