@page "/bakim-kabul"
@using MudBlazor
@using MroPlan.Models
@using MroPlan.Models.Enums
@using MroPlan.Services
@inject IBakimService BakimService
@inject IPersonelService PersonelService
@inject MroPlan.Services.ZamanYonetimServisi ZamanServisi
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Nav

<MudContainer MaxWidth="@MaxWidth.False" Class="mt-6 animate-fade-in">

    @* ─── BÖLÜM 1 — BAŞLIK VE AÇIKLAMA ─── *@
    <div class="d-flex align-center justify-space-between mb-6">
        <div>
            <div class="d-flex align-center gap-3">
                <div class="header-indicator"></div>
                <MudText Typo="Typo.h4" Style="font-weight:900; letter-spacing:-1.5px; text-transform:uppercase; color:#FACC15; font-family:'Outfit', sans-serif;">MRO Kabul Paneli</MudText>
            </div>
            <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.45); font-weight:600; margin-left:24px; font-family:'Inter', sans-serif;">
                Hava araçlarının atölye kabul süreçlerini, iş emri ilerlemelerini ve termin durumlarını takip edin.
            </MudText>
        </div>
    </div>

    @* ─── BÖLÜM 1 — KPI ŞERİDİ ─── *@
    <MudGrid Class="mb-6">
        @* Kart 1: Toplam Uçak *@
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-5 rounded-xxl d-flex align-center cyber-stat-card" Elevation="0" Style="border-left: 5px solid #FACC15;">
                <div class="pa-4 rounded-xl mr-4" style="background:rgba(250,204,21,0.08); color:#FACC15; box-shadow: 0 0 15px rgba(250,204,21,0.05);">
                    <MudIcon Icon="@Icons.Material.Filled.Flight" Size="Size.Large" />
                </div>
                <div>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.5); font-weight:700; letter-spacing: 0.05em; display:block;">TOPLAM UÇAK</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight:900; color:#FACC15; font-family: 'Outfit', sans-serif;">@_toplamUcak</MudText>
                </div>
            </MudPaper>
        </MudItem>

        @* Kart 2: Aktif Bakımda *@
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-5 rounded-xxl d-flex align-center cyber-stat-card" Elevation="0" Style="border-left: 5px solid #3B82F6;">
                <div class="pa-4 rounded-xl mr-4" style="background:rgba(59,130,246,0.08); color:#3B82F6; box-shadow: 0 0 15px rgba(59,130,246,0.05);">
                    <MudIcon Icon="@Icons.Material.Filled.Build" Size="Size.Large" />
                </div>
                <div>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.5); font-weight:700; letter-spacing: 0.05em; display:block;">AKTİF BAKIMDA</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight:900; color:#3B82F6; font-family: 'Outfit', sans-serif;">@_aktifSayisi</MudText>
                </div>
            </MudPaper>
        </MudItem>

        @* Kart 3: Bu Ay Tamamlanan *@
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-5 rounded-xxl d-flex align-center cyber-stat-card" Elevation="0" Style="border-left: 5px solid #10B981;">
                <div class="pa-4 rounded-xl mr-4" style="background:rgba(16,185,129,0.08); color:#10B981; box-shadow: 0 0 15px rgba(16,185,129,0.05);">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" />
                </div>
                <div>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.5); font-weight:700; letter-spacing: 0.05em; display:block;">BU AY TAMAMLANAN</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight:900; color:#10B981; font-family: 'Outfit', sans-serif;">@_buAyTamamlanan</MudText>
                </div>
            </MudPaper>
        </MudItem>

        @* Kart 4: Geciken *@
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-5 rounded-xxl d-flex align-center cyber-stat-card" Elevation="0" Style="border-left: 5px solid #EF4444;">
                <div class="pa-4 rounded-xl mr-4" style="background:rgba(239,68,68,0.08); color:#EF4444; box-shadow: 0 0 15px rgba(239,68,68,0.05);">
                    <MudIcon Icon="@Icons.Material.Filled.ReportProblem" Size="Size.Large" />
                </div>
                <div>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.5); font-weight:700; letter-spacing: 0.05em; display:block;">GECİKEN</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight:900; color:#EF4444; font-family: 'Outfit', sans-serif;">@_gecikenSayisi</MudText>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* ─── BÖLÜM 2 — FİLTRE & ARAMA ÇUBUĞU ─── *@
    <div class="d-flex flex-wrap align-center justify-space-between gap-4 mb-6 pa-4 rounded-xxl cyber-filter-bar" style="background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.05);">
        @* Sol: Durum filtre butonları *@
        <div class="d-flex align-center gap-2">
            <MudButtonGroup Variant="Variant.Outlined" Size="Size.Medium" Color="Color.Default" Class="rounded-lg overflow-hidden">
                <MudButton OnClick='() => { _durumFiltre = "Hepsi"; }'
                           Variant="@(_durumFiltre == "Hepsi" ? Variant.Filled : Variant.Outlined)"
                           Color="@(_durumFiltre == "Hepsi" ? Color.Primary : Color.Default)"
                           Style="font-weight:700;">Hepsi</MudButton>
                <MudButton OnClick='() => { _durumFiltre = "Aktif"; }'
                           Variant="@(_durumFiltre == "Aktif" ? Variant.Filled : Variant.Outlined)"
                           Color="@(_durumFiltre == "Aktif" ? Color.Info : Color.Default)"
                           Style="font-weight:700;">Aktif</MudButton>
                <MudButton OnClick='() => { _durumFiltre = "Tamamlandi"; }'
                           Variant="@(_durumFiltre == "Tamamlandi" ? Variant.Filled : Variant.Outlined)"
                           Color="@(_durumFiltre == "Tamamlandi" ? Color.Success : Color.Default)"
                           Style="font-weight:700;">Tamamlandı</MudButton>
                <MudButton OnClick='() => { _durumFiltre = "Geciken"; }'
                           Variant="@(_durumFiltre == "Geciken" ? Variant.Filled : Variant.Outlined)"
                           Color="@(_durumFiltre == "Geciken" ? Color.Error : Color.Default)"
                           Style="font-weight:700;">Geciken</MudButton>
            </MudButtonGroup>
        </div>

        @* Orta: Arama *@
        <div class="flex-grow-1 mx-md-4" style="max-width: 400px; min-width: 250px;">
            <MudTextField @bind-Value="_aramaMetni" Placeholder="Seri No, Heli Tipi veya Birlik Ara..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="rounded-lg cyber-search" />
        </div>

        @* Sağ: + YENİ KABUL *@
        <div>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="() => YeniKabulAc()"
                       Class="rounded-lg pa-3 px-6"
                       Style="font-weight:800; background:linear-gradient(135deg, #FACC15, #D97706); color:black; box-shadow:0 8px 15px rgba(250, 204, 21, 0.2);">
                + YENİ KABUL
            </MudButton>
        </div>
    </div>

    @* ─── BÖLÜM 3 — UÇAK KARTLARI GRİD ─── *@
    <MudGrid Spacing="6" Class="mb-8">
        @if (!_filtreliPlanlar.Any(AramaFiltresi))
        {
            <MudItem xs="12">
                <div class="pa-12 d-flex flex-column align-center justify-center rounded-xxl" style="background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.05); min-height: 300px;">
                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Style="color:rgba(255,255,255,0.15); font-size:4rem;" Class="mb-4" />
                    <MudText Typo="Typo.h6" Style="color:rgba(255,255,255,0.5); font-weight:700;">Hava Aracı Bulunamadı</MudText>
                    <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.35); text-align:center; max-width:400px;" Class="mt-2">
                        Arama kriterlerinize veya seçilen filtreye uygun kayıt bulunmamaktadır.
                    </MudText>
                </div>
            </MudItem>
        }
        else
        {
            @foreach (var plan in _filtreliPlanlar.Where(AramaFiltresi))
            {
                var context = plan; // local binding for safety
                var toplam = context.KontrolKayitlari?.Count ?? 0;
                var tamamlanan = context.KontrolKayitlari?.Count(k => k.Durum == "Tamamlandi") ?? 0;
                var yuzde = toplam > 0 ? (tamamlanan * 100 / toplam) : 0;
                
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudPaper Class="pa-6 rounded-xxl cyber-aircraft-card" Style="@GetCardStyle(context)" Elevation="0">
                        @* Top row: TipBadge & DurumChip *@
                        <div class="d-flex justify-space-between align-center mb-4">
                            <span class="tip-badge">@context.HeliTipi</span>
                            <MudChip T="string" Color="@GetDurumColor(context.GenelDurumEnum)" Size="Size.Small" Class="rounded-lg font-weight-bold" Style="height: 22px; font-size: 0.7rem;">
                                @context.GenelDurum
                            </MudChip>
                        </div>

                        @* Serial info & Large Heli Name *@
                        <div class="mb-4">
                            <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.4); font-weight:700; letter-spacing:0.05em; display:block;">
                                SERİ: @context.SeriNo
                            </MudText>
                            <MudText Typo="Typo.h5" Style="font-weight:900; color:white; letter-spacing:-0.5px; text-transform:uppercase; margin-top:2px;">
                                @context.HeliTipi
                            </MudText>
                        </div>

                        @* Details *@
                        @{
                            var beklemeGun = (int)(DateTime.Today - context.KabulTarihi.ToLocalTime().Date).TotalDays;
                            var beklemeRenk = beklemeGun > 60 ? "#EF4444" : beklemeGun > 30 ? "#F59E0B" : "#94A3B8";
                        }
                        <div class="d-flex flex-column gap-2 mb-4">
                            <div class="d-flex align-center justify-space-between">
                                <span style="font-size:0.75rem; color:rgba(255,255,255,0.4); font-weight:600;">Birlik:</span>
                                <span style="font-size:0.75rem; color:white; font-weight:700; text-align:right;">@context.GeldigiBirlik</span>
                            </div>
                            <div class="d-flex align-center justify-space-between">
                                <span style="font-size:0.75rem; color:rgba(255,255,255,0.4); font-weight:600;">Kabul:</span>
                                <div class="d-flex align-center gap-2">
                                    <span style="font-size:0.75rem; color:rgba(255,255,255,0.8); font-weight:700;">@context.KabulTarihi.ToLocalTime().ToString("dd.MM.yyyy")</span>
                                    <span style="font-size:0.65rem; font-weight:900; color:@beklemeRenk; background:color-mix(in srgb, @beklemeRenk 12%, transparent); border:1px solid color-mix(in srgb, @beklemeRenk 25%, transparent); border-radius:5px; padding:1px 6px; white-space:nowrap;">
                                        @beklemeGun g
                                    </span>
                                </div>
                            </div>
                        </div>

                        @* Work Order Progress *@
                        <div class="mb-4">
                            <div class="d-flex align-center justify-space-between mb-1">
                                <span style="font-size:0.7rem; color:rgba(255,255,255,0.45); font-weight:800; letter-spacing:0.05em;">İŞ EMRİ İLERLEMESİ</span>
                                <span style="font-size:0.7rem; color:#FACC15; font-weight:900;">@tamamlanan/@toplam (%@yuzde)</span>
                            </div>
                            <div class="progress-bar-container" style="background: rgba(255,255,255,0.06); height: 8px; border-radius: 4px; overflow: hidden; width: 100%;">
                                <div style="background: linear-gradient(90deg, #FACC15, #F59E0B); width: @(yuzde)%; height: 100%; border-radius: 4px; transition: width 0.4s ease; box-shadow: 0 0 8px rgba(250, 204, 21, 0.4);"></div>
                            </div>
                        </div>

                        @* Target Date / Kalan Gün *@
                        <div class="mb-6 pa-3 rounded-lg d-flex align-center justify-space-between" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04);">
                            <div>
                                <span style="font-size:0.65rem; color:rgba(255,255,255,0.35); font-weight:700; display:block;">HEDEF TESLİM</span>
                                <span style="font-size:0.75rem; color:white; font-weight:800;">
                                    @(context.HedefTeslimTarihi.HasValue ? context.HedefTeslimTarihi.Value.ToLocalTime().ToString("dd.MM.yyyy") : "Belirlenmedi")
                                </span>
                            </div>
                            <div>
                                @if (context.HedefTeslimTarihi.HasValue)
                                {
                                    var hedef = context.HedefTeslimTarihi.Value.ToLocalTime();
                                    var kalanGun = (hedef.Date - DateTime.Today).TotalDays;
                                    var gecikti = context.GenelDurumEnum != BakimDurumu.Tamamlandi && kalanGun < 0;
                                    var yaklasti = !gecikti && kalanGun <= 3;

                                    if (context.GenelDurumEnum == BakimDurumu.Tamamlandi)
                                    {
                                        <span class="kalan-gun-badge completed-badge">Tamamlandı</span>
                                    }
                                    else if (gecikti)
                                    {
                                        <span class="kalan-gun-badge delay-badge">@((int)-kalanGun)g gecikti</span>
                                    }
                                    else if (yaklasti)
                                    {
                                        <span class="kalan-gun-badge warning-badge">@((int)kalanGun)g kaldı</span>
                                    }
                                    else
                                    {
                                        <span class="kalan-gun-badge normal-badge">@((int)kalanGun)g kaldı</span>
                                    }
                                }
                                else
                                {
                                    <span class="kalan-gun-badge undefined-badge">Belirsiz</span>
                                }
                            </div>
                        </div>

                        @* Footer Buttons *@
                        <div class="d-flex align-center gap-2 pt-2" style="border-top:1px solid rgba(255,255,255,0.05);">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="rounded-lg flex-grow-1"
                                       Style="font-weight:700; font-size:0.75rem; height: 32px;"
                                       Disabled="@(context.GenelDurumEnum != BakimDurumu.Beklemede)"
                                       OnClick="@(() => Nav.NavigateTo($"/is-emri-dagitim?planId={context.Id}"))">
                                İş Emri
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" Class="rounded-lg flex-grow-1"
                                       Style="font-weight:700; font-size:0.75rem; height: 32px;"
                                       Disabled="@(context.GenelDurumEnum != BakimDurumu.DevamEdiyor)"
                                       OnClick='() => Nav.NavigateTo("/atolye-operasyon")'>
                                Atölye
                            </MudButton>

                            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small"
                                     AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true" Class="align-self-center">
                                <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Primary"
                                             OnClick="@(() => DuzenleHazirla(context))">Düzenle</MudMenuItem>
                                <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error"
                                             OnClick="@(() => SilBakim(context))">
                                    <span style="color:#ef4444;">Sil</span>
                                </MudMenuItem>
                            </MudMenu>
                        </div>

                        @* Rota Görüntüle *@
                        <div class="mt-2">
                            <MudButton Variant="Variant.Outlined" FullWidth="true" Size="Size.Small"
                                       Class="rounded-lg rota-btn"
                                       Style="font-weight:800; font-size:0.75rem; height:32px; border-color:rgba(250,204,21,0.3); color:#FACC15; letter-spacing:0.04em;"
                                       StartIcon="@Icons.Material.Filled.Route"
                                       OnClick="@(() => RotaGoster(context))">
                                ROTA GÖRÜNTÜLE
                            </MudButton>
                        </div>
                    </MudPaper>
                </MudItem>
            }
        }
    </MudGrid>
</MudContainer>

@* ─── ROTA MODAL ─── *@
@if (_rotaPlan != null)
{
    <div class="py-backdrop" @onclick="RotaKapat"></div>
    <div class="rota-modal-container" @onclick:stopPropagation="true">
        <div class="rota-modal">
            @* Modal Header *@
            <div class="rota-modal-header">
                <div>
                    <span class="rota-modal-title">BAKIM ROTASI</span>
                    <span class="rota-modal-subtitle">@_rotaPlan.HeliTipi &mdash; Seri: @_rotaPlan.SeriNo</span>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Medium"
                               Style="color:rgba(255,255,255,0.4);" OnClick="RotaKapat" />
            </div>

            @if (_rotaYukleniyor)
            {
                <div class="d-flex justify-center align-center pa-12">
                    <MudProgressCircular Color="Color.Warning" Indeterminate="true" Size="Size.Large" />
                </div>
            }
            else if (!_rotaSablonlari.Any())
            {
                <div class="d-flex flex-column align-center pa-12 gap-3">
                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size:3rem; color:rgba(255,255,255,0.2);" />
                    <MudText Style="color:rgba(255,255,255,0.4); font-weight:700;">Bu uçak tipi için rota şablonu tanımlı değil.</MudText>
                </div>
            }
            else
            {
                @* Özet şerit *@
                var toplamIslem = _rotaSablonlari.Sum(s => s.IslemSure);
                var toplamHazirlik = _rotaSablonlari.Sum(s => s.HazirlikSuresi);
                var grupSayisi = _rotaSablonlari.Select(s => s.BakimGrubuId).Distinct().Count();
                <div class="rota-ozet-serit">
                    <div class="rota-ozet-item">
                        <span class="rota-ozet-val">@grupSayisi</span>
                        <span class="rota-ozet-lbl">Atölye</span>
                    </div>
                    <div class="rota-ozet-sep"></div>
                    <div class="rota-ozet-item">
                        <span class="rota-ozet-val">@_rotaSablonlari.Count</span>
                        <span class="rota-ozet-lbl">İşlem</span>
                    </div>
                    <div class="rota-ozet-sep"></div>
                    <div class="rota-ozet-item">
                        <span class="rota-ozet-val" style="color:#FACC15;">@FormatDk(toplamIslem)</span>
                        <span class="rota-ozet-lbl">Toplam İşçilik</span>
                    </div>
                    <div class="rota-ozet-sep"></div>
                    <div class="rota-ozet-item">
                        <span class="rota-ozet-val" style="color:#94A3B8;">@FormatDk(toplamHazirlik)</span>
                        <span class="rota-ozet-lbl">Toplam Setup</span>
                    </div>
                </div>

                @* Rota Zinciri *@
                <div class="rota-chain-wrapper">
                    <div class="rota-chain">
                        @{
                            var gruplar = _rotaSablonlari
                                .GroupBy(s => s.BakimGrubuId)
                                .OrderBy(g => g.Min(s => s.SiraNo))
                                .ToList();

                            // Atölye renkleri
                            string[] atolyeRenkler = {
                                "#3B82F6", "#8B5CF6", "#10B981", "#F59E0B",
                                "#EF4444", "#06B6D4", "#EC4899", "#84CC16"
                            };
                        }

                        @for (int gi = 0; gi < gruplar.Count; gi++)
                        {
                            var grup = gruplar[gi];
                            var parcalar = grup.OrderBy(s => s.SiraNo).ThenBy(s => s.ParcaAdi).ToList();
                            var grupAdi = parcalar.FirstOrDefault()?.BakimGrubu?.GrupAdi ?? $"Atölye {grup.Key}";
                            var atolyeKodu = parcalar.FirstOrDefault()?.BakimGrubu?.AtolyeKodu ?? "";
                            var renk = atolyeRenkler[gi % atolyeRenkler.Length];
                            var toplamSure = parcalar.Sum(p => p.IslemSure);
                            var idx = gi; // local capture

                            @* Atölye Kartı *@
                            <div class="rota-atolye-card" style="--atolye-renk:@renk; animation-delay:@(idx * 0.12)s;">
                                @* Kart Başlık *@
                                <div class="rota-atolye-header" style="background:linear-gradient(135deg, @renk 0%, @(renk)88 100%);">
                                    <div class="rota-atolye-no">@(idx + 1)</div>
                                    <div>
                                        <div class="rota-atolye-ad">@grupAdi</div>
                                        @if (!string.IsNullOrEmpty(atolyeKodu))
                                        {
                                            <div class="rota-atolye-kod">@atolyeKodu</div>
                                        }
                                    </div>
                                    <div class="rota-atolye-toplam-sure">@FormatDk(toplamSure)</div>
                                </div>

                                @* Parçalar Listesi *@
                                <div class="rota-parcalar-liste">
                                    @foreach (var (parca, pi) in parcalar.Select((p, i) => (p, i)))
                                    {
                                        <div class="rota-parca-satir" style="animation-delay:@(idx * 0.12 + pi * 0.06 + 0.06)s;">
                                            @if (parca.HazirlikSuresi > 0 && pi > 0)
                                            {
                                                <div class="rota-parca-setup">
                                                    <span class="material-icons" style="font-size:11px;">hardware</span>
                                                    @FormatDk(parca.HazirlikSuresi)
                                                </div>
                                            }
                                            <div class="rota-parca-kutu" style="--parca-renk:@renk;">
                                                <div class="rota-parca-sure-badge">@FormatDk(parca.IslemSure)</div>
                                                <div class="rota-parca-adi-text">@parca.ParcaAdi</div>
                                                <div class="rota-parca-pn">@parca.ParcaPN</div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>

                            @* Atölyeler arası boşluk *@
                            @if (gi < gruplar.Count - 1)
                            {
                                <div style="width:24px; flex-shrink:0;"></div>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}

@* ─── BÖLÜM 4 — SLIDE-OVER KABUL FORMU ─── *@
@if (_formAcik)
{
    <div class="py-backdrop" @onclick="Vazgec"></div>
    <div class="py-panel-container">
        <div class="py-panel">
            <div class="d-flex align-center justify-space-between mb-6" style="border-bottom:1px solid rgba(255,255,255,0.06); padding-bottom:16px;">
                <div>
                    <MudText Typo="Typo.h5" Style="font-weight:900; color:#FACC15; font-family:'Outfit', sans-serif; text-transform:uppercase;">
                        @(_isEdit ? "Hava Aracı Düzenle" : "Yeni Kabul Girişi")
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.4); font-weight:600;">
                        @(_isEdit ? $"{_yeniPlan.SeriNo} seri numaralı kaydı güncelleyin." : "Yeni hava aracı kabul detaylarını doldurun.")
                    </MudText>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="Vazgec" Size="Size.Medium" Style="color:rgba(255,255,255,0.35);" />
            </div>

            <div class="d-flex flex-column gap-5">
                <MudTextField @bind-Value="_yeniPlan.SeriNo" Label="Seri Numarası"
                              Variant="Variant.Outlined" Required="true" Placeholder="Örn: 0501" />

                <MudSelect T="string" Label="Helikopter Tipi"
                           Value="_yeniPlan.HeliTipi"
                           ValueChanged="@(async (string tip) => { _yeniPlan.HeliTipi = tip; await OtomatikHesapla(); })"
                           Disabled="@_hesaplaniyor"
                           Variant="Variant.Outlined" Required="true">
                    @foreach (var tip in HeliTipleri.Hepsi)
                    {
                        <MudSelectItem Value="@tip" />
                    }
                </MudSelect>

                <MudSelect T="string" Label="Geldiği Birlik / Komutanlık" @bind-Value="_yeniPlan.GeldigiBirlik"
                           Variant="Variant.Outlined" Required="true">
                    <MudSelectItem Value="@("Deniz Havacılık K.")" />
                    <MudSelectItem Value="@("Emniyet Hav. D.")" />
                    <MudSelectItem Value="@("Jandarma Hav. K.")" />
                    <MudSelectItem Value="@("Kara Havacılık K.")" />
                    <MudSelectItem Value="@("Özel Kuvvetler")" />
                </MudSelect>

                @* ─── HEDEF TESLİM TARİHİ ─── *@
                <div class="mt-2">
                    <MudText Typo="Typo.caption" Class="mb-2 d-block" Style="color:rgba(255,255,255,0.5); font-weight:700; letter-spacing:.05em;">
                        HEDEF TESLİM TARİHİ
                    </MudText>

                    <MudDatePicker @bind-Date="_hedefTarihNullable"
                                   Variant="Variant.Outlined"
                                   DateFormat="dd.MM.yyyy"
                                   Placeholder="Tarih seçin veya otomatik hesaplayın"
                                   PickerVariant="PickerVariant.Dialog"
                                   MinDate="DateTime.Today" />

                </div>

                <div class="d-flex flex-column gap-2 mt-4">
                    <MudButton Variant="Variant.Filled"
                               Color="@(_isEdit ? Color.Info : Color.Primary)"
                               FullWidth="true" Class="rounded-xl py-4"
                               Style="font-weight:900; background:linear-gradient(135deg, #FACC15, #D97706); color:black; font-size:1rem; box-shadow: 0 10px 20px rgba(250, 204, 21, 0.15);"
                               OnClick="BakimKaydet"
                               StartIcon="@(_isEdit ? Icons.Material.Filled.Save : Icons.Material.Filled.FlightTakeoff)">
                        @(_isEdit ? "GÜNCELLEMEYİ TAMAMLA" : "KABULÜ TAMAMLA")
                    </MudButton>

                    <MudButton Variant="Variant.Text" Color="Color.Default" FullWidth="true" OnClick="Vazgec" Class="py-2" Style="color:rgba(255,255,255,0.4); font-weight:600;">
                        VAZGEÇ / KAPAT
                    </MudButton>
                </div>
            </div>
        </div>
    </div>
}

