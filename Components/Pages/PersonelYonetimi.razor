@page "/personel-yonetimi"
@using MudBlazor
@using MroPlan.Models
@using MroPlan.Models.Enums
@using MroPlan.Services
@using MroPlan.Data
@using Microsoft.EntityFrameworkCore
@inject IPersonelService PersonelService
@inject ApplicationDbContext Context
@inject IYetkinlikService YetkinlikService
@inject ISnackbar Snackbar
@inject MudBlazor.IDialogService DialogService
@inject IJSRuntime JS

<MudContainer MaxWidth="@MaxWidth.False" Class="mt-8 animate-fade-in">

    @* --- 6 STAT KARTLARI --- *@
    <MudGrid Class="mb-8">
        <MudItem xs="12" sm="6" md="4" lg="2">
            <MudPaper Class="pa-5 rounded-xxl d-flex align-center" Elevation="0" Style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);">
                <div class="pa-3 rounded-lg mr-3" style="background:linear-gradient(135deg, #FACC15, #D97706);color:black;">
                    <MudIcon Icon="@Icons.Material.Filled.People" />
                </div>
                <div>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.5);font-weight:700;">TOPLAM</MudText>
                    <MudText Typo="Typo.h5" Style="font-weight:800;">@_personeller.Count</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="4" lg="2">
            <MudPaper Class="pa-5 rounded-xxl d-flex align-center" Elevation="0" Style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);">
                <div class="pa-3 rounded-lg mr-3" style="background:#16A34A;color:white;">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
                </div>
                <div>
                    <MudText Typo="Typo.caption" Style="color:#22C55E;font-weight:700;">AKTİF</MudText>
                    <MudText Typo="Typo.h5" Style="font-weight:800;color:#22C55E;">@_stats.GetValueOrDefault("Aktif", 0)</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="4" lg="2">
            <MudPaper Class="pa-5 rounded-xxl d-flex align-center" Elevation="0" Style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);">
                <div class="pa-3 rounded-lg mr-3" style="background:#CA8A04;color:white;">
                    <MudIcon Icon="@Icons.Material.Filled.EventBusy" />
                </div>
                <div>
                    <MudText Typo="Typo.caption" Style="color:#FACC15;font-weight:700;">İZİNLİ</MudText>
                    <MudText Typo="Typo.h5" Style="font-weight:800;color:#FACC15;">@_stats.GetValueOrDefault("Izinli", 0)</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="4" lg="2">
            <MudPaper Class="pa-5 rounded-xxl d-flex align-center" Elevation="0" Style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);">
                <div class="pa-3 rounded-lg mr-3" style="background:#7C3AED;color:white;">
                    <MudIcon Icon="@Icons.Material.Filled.School" />
                </div>
                <div>
                    <MudText Typo="Typo.caption" Style="color:#A78BFA;font-weight:700;">EĞİTİMDE</MudText>
                    <MudText Typo="Typo.h5" Style="font-weight:800;color:#A78BFA;">@_stats.GetValueOrDefault("Egitimde", 0)</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="4" lg="2">
            <MudPaper Class="pa-5 rounded-xxl d-flex align-center" Elevation="0" Style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);">
                <div class="pa-3 rounded-lg mr-3" style="background:#0EA5E9;color:white;">
                    <MudIcon Icon="@Icons.Material.Filled.FlightTakeoff" />
                </div>
                <div>
                    <MudText Typo="Typo.caption" Style="color:#38BDF8;font-weight:700;">GÖREVLİ</MudText>
                    <MudText Typo="Typo.h5" Style="font-weight:800;color:#38BDF8;">@_stats.GetValueOrDefault("Gorevli", 0)</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="4" lg="2">
            <MudPaper Class="pa-5 rounded-xxl d-flex align-center" Elevation="0" Style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);">
                <div class="pa-3 rounded-lg mr-3" style="background:#E11D48;color:white;">
                    <MudIcon Icon="@Icons.Material.Filled.PersonRemove" />
                </div>
                <div>
                    <MudText Typo="Typo.caption" Style="color:#FB7185;font-weight:700;">AYRILDI</MudText>
                    <MudText Typo="Typo.h5" Style="font-weight:800;color:#FB7185;">@_stats.GetValueOrDefault("Ayrildi", 0)</MudText>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <div class="d-flex align-center justify-space-between mb-8">
        <div>
            <MudText Typo="Typo.h4" Style="font-weight:800;">PERSONEL YÖNETİMİ</MudText>
            <MudText Typo="Typo.body1" Style="color:rgba(255,255,255,0.5);">Tüm bakım personeli listesi ve yetkinlik takibi.</MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="EkleDialog" Class="rounded-lg pa-3 px-6" Style="font-weight:800;">YENİ PERSONEL</MudButton>
    </div>

    <MudTable T="Personel" Items="@_personeller" Hover="true" Elevation="0" Loading="@_yukleniyor"
              Filter="new Func<Personel, bool>(SearchFilter)" Class="rounded-xxl overflow-hidden border border-slate-200">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Personel Listesi</MudText>
            <MudSpacer />
            <MudSelect T="string" Label="Durum" @bind-Value="_filterDurum" Clearable="true"
                       Variant="Variant.Outlined" Margin="Margin.Dense"
                       Style="min-width:130px;margin-right:8px;">
                @foreach (PersonelDurumu d in Enum.GetValues(typeof(PersonelDurumu)))
                {
                    <MudSelectItem Value="@d.ToString()">@DurumAdiStr(d)</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="string" Label="Atölye" @bind-Value="_filterAtolye" Clearable="true"
                       Variant="Variant.Outlined" Margin="Margin.Dense"
                       Style="min-width:150px;margin-right:8px;">
                @foreach (var bg in _bakimGruplari)
                {
                    <MudSelectItem Value="@bg.AtolyeKodu">@bg.GrupAdi</MudSelectItem>
                }
            </MudSelect>
            <MudTextField T="string" @bind-Value="_searchString" Placeholder="Personel Ara..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="rounded-lg"
                          Style="max-width:260px;" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<Personel, object>(p => p.SicilNo)">Sicil</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<Personel, object>(p => p.AdSoyad)">Ad Soyad</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<Personel, object>(p => p.Unvan ?? string.Empty)">Ünvan</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<Personel, object>(p => GetAtolyeAdi(p.AtolyeKodu))">Atölye</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<Personel, object>(p => p.Durum)">Durum</MudTableSortLabel></MudTh>
            <MudTh Style="width:60px;"></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><b>@context.SicilNo</b></MudTd>
            <MudTd>@context.AdSoyad</MudTd>
            <MudTd>@context.Unvan</MudTd>
            <MudTd>@GetAtolyeAdi(context.AtolyeKodu)</MudTd>
            <MudTd>
                <div class="d-flex align-center" style="gap:6px;">
                    <MudChip T="string" Color="@GetDurumColor(context.DurumEnum)" Size="Size.Small" Variant="Variant.Filled" Class="rounded-lg">@DurumAdiStr(context.DurumEnum)</MudChip>
                    @if (IzinBitisUyarisi(context))
                    {
                        <MudTooltip Text="@($"İzin bitiş: {context.IzinBitis!.Value:dd.MM.yyyy}")">
                            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" />
                        </MudTooltip>
                    }
                </div>
            </MudTd>
            <MudTd Style="text-align:right;">
                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
                    <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Secondary" OnClick="@(() => DetayAc(context))">Görüntüle</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Primary" OnClick="@(() => DuzenleDialog(context))">Düzenle</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.MilitaryTech" IconColor="Color.Info" Href="/yetkinlik">Yetkinlik & Geliştirme</MudMenuItem>
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" OnClick="@(() => SilOnay(context))">
                        <MudText Color="Color.Error">Sil</MudText>
                    </MudMenuItem>
                </MudMenu>
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudContainer>

@* --- DETAY PANELİ --- *@
@if (_detayAcik && _detayPersonel != null)
{
    <div class="py-backdrop" @onclick="DetayKapat"></div>
    <div class="py-panel-container">
        <div class="py-panel">
            <div class="d-flex align-center justify-space-between mb-4">
                <MudText Typo="Typo.h5" Style="font-weight:900; color:var(--gold);">Personel Dosyası</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="DetayKapat" Size="Size.Medium" Style="color:rgba(255,255,255,0.3);" />
            </div>

        <div class="row g-4">
            @* SOL SÜTUN *@
            <div class="col-12 col-lg-6">
                <div class="d-flex align-center mb-5">
                    <div class="py-avatar mr-4">@AvatarText(_detayPersonel)</div>
                    <div>
                        <div class="d-flex align-center mb-1" style="gap:8px;">
                            <MudChip T="string" Color="@GetDurumColor(_detayPersonel.DurumEnum)" Size="Size.Small" Variant="Variant.Filled" Class="rounded-lg ma-0" Style="font-size:0.6rem; font-weight:900; height:18px;">@DurumAdiStr(_detayPersonel.DurumEnum)</MudChip>
                            <MudText Typo="Typo.h6" Style="font-weight:800; line-height:1.2;">@_detayPersonel.AdSoyad</MudText>
                        </div>
                        <MudText Typo="Typo.body2" Style="color:#64748B; font-weight:600; font-size:0.75rem;">@(_detayPersonel.Unvan ?? "-")</MudText>
                        <MudText Typo="Typo.body2" Style="color:#64748B; font-size:0.75rem;">@GetAtolyeAdi(_detayPersonel.AtolyeKodu)</MudText>
                    </div>
                </div>

                @if (_detayPersonel.IzinBaslangic.HasValue || _detayPersonel.IzinBitis.HasValue)
                {
                    <div class="mb-4 pa-3 rounded-lg" style="background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.05);">
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.5); font-weight:800; display:block; margin-bottom:4px;">İZİN BİLGİSİ</MudText>
                        <div class="d-flex gap-4">
                            @if (_detayPersonel.IzinBaslangic.HasValue)
                            {
                                <div>
                                    <MudText Typo="Typo.caption" Style="color:#64748B; display:block;">Başlangıç</MudText>
                                    <MudText Typo="Typo.body2" Style="font-weight:700;">@_detayPersonel.IzinBaslangic.Value.ToString("dd.MM.yyyy")</MudText>
                                </div>
                            }
                            @if (_detayPersonel.IzinBitis.HasValue)
                            {
                                <div>
                                    <MudText Typo="Typo.caption" Style="color:#64748B; display:block;">Bitiş</MudText>
                                    <MudText Typo="Typo.body2" Style="font-weight:700;">@_detayPersonel.IzinBitis.Value.ToString("dd.MM.yyyy")</MudText>
                                </div>
                            }
                        </div>
                    </div>
                }

                <MudDivider Class="mb-4" />

                @if (_detayYukleniyor)
                {
                    <div class="d-flex justify-center pa-4">
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Primary" />
                    </div>
                }
                else
                {
                    <MudText Typo="Typo.subtitle2" Style="font-weight:800;margin-bottom:12px;">SERTİFİKA İSTATİSTİKLERİ</MudText>
                    <div class="d-flex mb-5" style="gap:12px;">
                        <div class="py-stat-box">
                            <MudText Typo="Typo.h5" Style="font-weight:800;">@_detaySertifikaCount</MudText>
                            <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.5);">Toplam Sertifika</MudText>
                        </div>
                        <div class="py-stat-box">
                            <MudText Typo="Typo.h5" Style="font-weight:800;color:#16A34A;">@_detayUzmanCount</MudText>
                            <MudText Typo="Typo.caption" Style="color:#64748B;">Uzman (Lv ≥ 4)</MudText>
                        </div>
                    </div>

                    @if (_detayHeliStats.Count > 0)
                    {
                        <MudText Typo="Typo.subtitle2" Style="font-weight:800;margin-bottom:10px;">HELİKOPTER TİPİ BAŞINA</MudText>
                        @foreach (var (heliTipi, adet, ortSeviye) in _detayHeliStats)
                        {
                            <div class="mb-3">
                                <div class="d-flex justify-space-between align-center mb-1">
                                    <MudText Typo="Typo.body2" Style="font-weight:600;">@heliTipi</MudText>
                                    <MudText Typo="Typo.caption" Style="color:#64748B;">@adet parça · Ort: @ortSeviye.ToString("F1")</MudText>
                                </div>
                                <MudProgressLinear Value="@(ortSeviye / 5.0 * 100)" Color="Color.Primary" Rounded="true" Size="Size.Small" />
                            </div>
                        }
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Style="color:#94A3B8;">Sertifika kaydı bulunamadı.</MudText>
                    }
                }
            </div>

            @* SAĞ SÜTUN (RADAR) *@
            <div class="col-12 col-lg-6 d-flex flex-column align-center justify-center">
                @if (!_detayYukleniyor && _detayRadarPoints.Count >= 3)
                {
                    <div class="pa-4 rounded-xxl" style="background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.04); width:100%;">
                        <MudText Typo="Typo.subtitle2" Style="font-weight:800;margin-bottom:2px; text-align:center;">YETENEK RADARI</MudText>
                        <MudText Typo="Typo.caption" Style="color:#64748B;display:block;margin-bottom:20px; text-align:center;">Heli tipi başına ortalama yetkinlik seviyesi</MudText>
                        
                        <div class="d-flex justify-center">
                            <svg width="340" height="340" viewBox="0 0 300 300" style="overflow:visible;">
                                @for (int ri = 1; ri <= 5; ri++)
                                {
                                    <circle cx="150" cy="150" r="@(ri * 22)" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="1" stroke-dasharray="4" />
                                }
                                @{
                                    var tPath = GetPersonelRadarPath(_detayRadarPoints.Select(_ => 100.0).ToList());
                                    var aPath = GetPersonelRadarPath(_detayRadarPoints.Select(x => x.Actual).ToList());
                                }
                                <path d="@tPath" fill="rgba(59,130,246,.05)" stroke="rgba(59,130,246,0.3)" stroke-width="1" />
                                <path d="@aPath" fill="rgba(250,204,21,.15)" stroke="var(--gold)" stroke-width="3" stroke-linecap="round" style="filter: drop-shadow(0 0 8px rgba(250,204,21,0.4));" />
                                @for (int ri = 0; ri < _detayRadarPoints.Count; ri++)
                                {
                                    var angle = (ri * 2 * Math.PI / _detayRadarPoints.Count) - Math.PI / 2;
                                    <line x1="150" y1="150"
                                          x2="@((150 + 110 * Math.Cos(angle)).ToString("F1", System.Globalization.CultureInfo.InvariantCulture))"
                                          y2="@((150 + 110 * Math.Sin(angle)).ToString("F1", System.Globalization.CultureInfo.InvariantCulture))"
                                          stroke="rgba(255,255,255,0.1)" stroke-width="1" />
                                    @((MarkupString)$"<text x=\"{(150 + 135 * Math.Cos(angle)).ToString("F1", System.Globalization.CultureInfo.InvariantCulture)}\" y=\"{(150 + 135 * Math.Sin(angle)).ToString("F1", System.Globalization.CultureInfo.InvariantCulture)}\" text-anchor=\"middle\" dominant-baseline=\"middle\" font-size=\"9\" font-weight=\"800\" fill=\"#94A3B8\">{_detayRadarPoints[ri].Label}</text>")
                                }
                            </svg>
                        </div>
                        
                        <div class="d-flex justify-center mt-6" style="gap:24px;">
                            <div class="d-flex align-center gap-2">
                                <div style="width:12px;height:12px;background:rgba(59,130,246,0.3);border:1px solid #3b82f6;border-radius:3px;"></div>
                                <span style="font-size:11px;color:#64748B;font-weight:700;">Hedef (Lv5)</span>
                            </div>
                            <div class="d-flex align-center gap-2">
                                <div style="width:12px;height:12px;background:rgba(250,204,21,0.2);border:1px solid var(--gold);border-radius:3px;"></div>
                                <span style="font-size:11px;color:var(--gold);font-weight:700;">Mevcut</span>
                            </div>
                        </div>
                    </div>
                }
                else if (!_detayYukleniyor)
                {
                    <div class="pa-10 text-center" style="opacity:0.3;">
                        <MudIcon Icon="@Icons.Material.Filled.Radar" Size="Size.Large" Class="mb-2" />
                        <MudText Typo="Typo.body2">Radar için en az 3 heli tipi verisi gerekir.</MudText>
                    </div>
                }
            </div>
        </div>

        @* ─── ALINAN EĞİTİMLER ─── *@
        @if (!_detayYukleniyor && _detayEgitimler.Count > 0)
        {
            <div class="mt-5">
                <MudDivider Class="mb-4" />
                <MudText Typo="Typo.subtitle2" Style="font-weight:800; margin-bottom:12px; color:var(--gold);">ALINAN EĞİTİMLER</MudText>
                <div style="overflow-x:auto;">
                    <table style="width:100%; border-collapse:collapse; font-size:0.78rem;">
                        <thead>
                            <tr style="color:rgba(255,255,255,0.4); font-size:0.65rem; font-weight:800; text-transform:uppercase; letter-spacing:.05em;">
                                <th style="padding:6px 10px; text-align:left; border-bottom:1px solid rgba(255,255,255,0.06);">EĞİTİM</th>
                                <th style="padding:6px 10px; text-align:left; border-bottom:1px solid rgba(255,255,255,0.06);">PARÇA</th>
                                <th style="padding:6px 10px; text-align:center; border-bottom:1px solid rgba(255,255,255,0.06);">HEDEF SV</th>
                                <th style="padding:6px 10px; text-align:center; border-bottom:1px solid rgba(255,255,255,0.06);">DURUM</th>
                                <th style="padding:6px 10px; text-align:center; border-bottom:1px solid rgba(255,255,255,0.06);">TAMAMLANMA</th>
                                <th style="padding:6px 10px; text-align:center; border-bottom:1px solid rgba(255,255,255,0.06);">SERTİFİKA</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var eg in _detayEgitimler)
                            {
                                var parcaId = eg.EgitimModulu?.ParcaSablonuId;
                                var ytk = parcaId.HasValue
                                    ? _detayYetkinlikler.FirstOrDefault(y => y.ParcaSablonuId == parcaId.Value)
                                    : null;
                                <tr style="border-bottom:1px solid rgba(255,255,255,0.04);">
                                    <td style="padding:8px 10px; font-weight:700;">@(eg.EgitimModulu?.Ad ?? "—")</td>
                                    <td style="padding:8px 10px; color:rgba(255,255,255,0.5);">@(eg.EgitimModulu?.ParcaSablonu?.ParcaAdi ?? "—")</td>
                                    <td style="padding:8px 10px; text-align:center;">
                                        @{ var hedef = eg.EgitimModulu?.HedefYetkinlikSeviyesi ?? 0; }
                                        <span style="background:@(hedef <= 1 ? "rgba(168,85,247,0.15)" : hedef == 2 ? "rgba(59,130,246,0.15)" : hedef == 3 ? "rgba(245,158,11,0.15)" : "rgba(16,185,129,0.15)"); color:@(hedef <= 1 ? "#a855f7" : hedef == 2 ? "#3B82F6" : hedef == 3 ? "#F59E0B" : "#10B981"); font-weight:900; font-size:0.65rem; padding:3px 8px; border-radius:6px;">
                                            SV@(hedef)
                                        </span>
                                    </td>
                                    <td style="padding:8px 10px; text-align:center;">
                                        @if (eg.Tamamlandi)
                                        {
                                            <span style="background:rgba(16,185,129,0.12); color:#10B981; font-weight:800; font-size:0.65rem; padding:3px 8px; border-radius:6px;">TAMAMLANDI</span>
                                        }
                                        else
                                        {
                                            <span style="background:rgba(168,85,247,0.12); color:#a855f7; font-weight:800; font-size:0.65rem; padding:3px 8px; border-radius:6px;">EĞİTİMDE</span>
                                        }
                                    </td>
                                    <td style="padding:8px 10px; text-align:center; color:rgba(255,255,255,0.5);">
                                        @(eg.Tamamlandi ? eg.TamamlanmaTarihi.ToLocalTime().ToString("dd.MM.yyyy") : (eg.PlanlananBitis.HasValue ? eg.PlanlananBitis.Value.ToLocalTime().ToString("dd.MM.yyyy") + " (plan)" : "—"))
                                    </td>
                                    <td style="padding:8px 10px; text-align:center;">
                                        @if (eg.Tamamlandi && ytk?.SertifikaBelgeNo != null)
                                        {
                                            var egLocal = eg; var ytkLocal = ytk;
                                            <button @onclick="@(() => AcSertifika(ytkLocal!, egLocal))"
                                                    style="background:rgba(250,204,21,0.08); color:#FACC15; border:1px solid rgba(250,204,21,0.3);
                                                           border-radius:6px; padding:3px 8px; font-size:0.6rem; font-weight:900;
                                                           cursor:pointer; white-space:nowrap; letter-spacing:.03em;"
                                                    title="Sertifikayı görüntüle ve yazdır">
                                                🏅 @(ytk!.SertifikaBelgeNo)
                                            </button>
                                        }
                                        else
                                        {
                                            <span style="color:rgba(255,255,255,0.2); font-size:0.65rem;">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        </div>
    </div>
}

@* ─── SERTİFİKA MODAL ─── *@
@if (_sertifikaAcik && _sertifikaYtk != null && _sertifikaEgitim != null && _detayPersonel != null)
{
    <div class="cert-backdrop" @onclick="@(() => _sertifikaAcik = false)"></div>
    <div class="cert-container">
        <div class="cert-wrapper" @onclick:stopPropagation="true">

            @* Toolbar *@
            <div class="cert-toolbar">
                <span style="font-weight:700; color:rgba(255,255,255,0.5); font-size:0.8rem;">SERTİFİKA ÖNİZLEME</span>
                <div class="d-flex gap-2">
                    <button class="cert-btn-print" @onclick="YazdirSertifika">
                        🖨️ YAZDIR / PDF
                    </button>
                    <button class="cert-btn-close" @onclick="@(() => _sertifikaAcik = false)">✕</button>
                </div>
            </div>

            @* Sertifika Belgesi *@
            <div class="cert-doc" id="cert-print-area">

                @* Üst dekoratif şerit *@
                <div class="cert-top-bar"></div>

                @* Header *@
                <div class="cert-header">
                    <div class="cert-logo-area">
                        <div class="cert-logo-icon">✈</div>
                        <div>
                            <div class="cert-org-name">MROPlan</div>
                            <div class="cert-org-sub">Bakım, Onarım ve Revizyon Yönetim Sistemi</div>
                        </div>
                    </div>
                    <div class="cert-badge-area">
                        <div class="cert-sv-badge">SV@(_sertifikaEgitim.EgitimModulu?.HedefYetkinlikSeviyesi ?? 0)</div>
                        <div class="cert-sv-label">YETKİNLİK SEVİYESİ</div>
                    </div>
                </div>

                <div class="cert-divider"></div>

                @* Ana başlık *@
                <div class="cert-title-block">
                    <div class="cert-title-tr">YETKİNLİK SERTİFİKASI</div>
                    <div class="cert-title-en">COMPETENCY CERTIFICATE</div>
                </div>

                @* Açıklama metni *@
                <div class="cert-description">
                    Bu belge, aşağıda bilgileri yer alan personelin belirtilen uçak bakım parçasında
                    gerekli yetkinlik seviyesine ulaştığını ve ilgili bakım faaliyetlerini
                    yürütmeye yetkili olduğunu onaylar.
                </div>

                @* Bilgi grid *@
                <div class="cert-info-grid">
                    <div class="cert-info-block cert-info-left">
                        <div class="cert-info-section-title">PERSONEL BİLGİLERİ</div>
                        <div class="cert-info-row"><span class="cert-label">Ad Soyad</span><span class="cert-value">@_detayPersonel.AdSoyad</span></div>
                        <div class="cert-info-row"><span class="cert-label">Sicil No</span><span class="cert-value">@_detayPersonel.SicilNo</span></div>
                        <div class="cert-info-row"><span class="cert-label">Ünvan</span><span class="cert-value">@(_detayPersonel.Unvan ?? "—")</span></div>
                        <div class="cert-info-row"><span class="cert-label">Atölye</span><span class="cert-value">@GetAtolyeAdi(_detayPersonel.AtolyeKodu)</span></div>
                    </div>
                    <div class="cert-info-block cert-info-right">
                        <div class="cert-info-section-title">YETKİNLİK BİLGİLERİ</div>
                        <div class="cert-info-row"><span class="cert-label">Parça Adı</span><span class="cert-value">@(_sertifikaEgitim.EgitimModulu?.ParcaSablonu?.ParcaAdi ?? "—")</span></div>
                        <div class="cert-info-row"><span class="cert-label">Part No</span><span class="cert-value cert-mono">@(_sertifikaYtk.ParcaPN ?? "—")</span></div>
                        <div class="cert-info-row"><span class="cert-label">Heli Tipi</span><span class="cert-value">@(_sertifikaEgitim.EgitimModulu?.ParcaSablonu?.HeliTipi ?? "—")</span></div>
                        <div class="cert-info-row"><span class="cert-label">Eğitim</span><span class="cert-value">@(_sertifikaEgitim.EgitimModulu?.Ad ?? "—")</span></div>
                    </div>
                </div>

                @* Sertifika numarası ve tarih *@
                <div class="cert-number-row">
                    <div class="cert-number-block">
                        <div class="cert-number-label">SERTİFİKA NO</div>
                        <div class="cert-number-value">@_sertifikaYtk.SertifikaBelgeNo</div>
                    </div>
                    <div class="cert-number-block">
                        <div class="cert-number-label">DÜZENLEME TARİHİ</div>
                        <div class="cert-number-value">@(_sertifikaYtk.SertifikaTarihi?.ToLocalTime().ToString("dd.MM.yyyy") ?? "—")</div>
                    </div>
                    <div class="cert-number-block">
                        <div class="cert-number-label">KATEGORİ</div>
                        <div class="cert-number-value">OJT / On-the-Job Training</div>
                    </div>
                </div>

                @* Alt bölüm: imza + mühür *@
                <div class="cert-footer">
                    <div class="cert-sign-area">
                        <div class="cert-sign-line"></div>
                        <div class="cert-sign-label">Onaylayan — Approver</div>
                    </div>
                    <div class="cert-stamp">
                        <div class="cert-stamp-inner">
                            <div class="cert-stamp-text">MROPlan</div>
                            <div class="cert-stamp-sub">ONAYLIDIR</div>
                        </div>
                    </div>
                    <div class="cert-sign-area">
                        <div class="cert-sign-line"></div>
                        <div class="cert-sign-label">Personel — Certificate Holder</div>
                    </div>
                </div>

                @* Alt dekoratif şerit *@
                <div class="cert-bottom-bar"></div>
            </div>
        </div>
    </div>
}

