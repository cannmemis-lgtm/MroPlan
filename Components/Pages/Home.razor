    protected override async Task OnInitializedAsync()
    {
        stats = await PersonelService.GetPersonelStatsAsync();
        var planlar = await BakimService.GetBakimPlanlariAsync();
        _dashStats = await BakimService.GetDashboardStatsAsync();

        trendData = _dashStats.HaftalikTrend
            .Select(t => new ChartData { Label = t.Gun, Value = t.Sayi })
            .ToList();
        pieData = stats
            .Select(x => new ChartData { Label = x.Key, Value = (decimal?)x.Value })
            .ToList();

        await HesaplaMetriklerAsync(planlar);

        // Risk seviyesi — senaryo servisi hatası dashboard'u engellemez
        try
        {
            var senaryo = await PlanlamaService.SenaryoAnalizeEtAsync(
                new SenaryoParametreleri(0, 0, 0, DateTime.Now.Year, DateTime.Now.Month));
            _riskSeviyesi = senaryo.RiskSeviyesi;
            _riskRengi = senaryo.RiskSeviyesi switch
            {
                "KRİTİK" => "239,68,68",
                "YÜKSEK" => "249,115,22",
                "ORTA"   => "250,204,21",
                _        => "34,197,94"
            };
        }
        catch { /* sessiz hata */ }
    }

    private async Task HesaplaMetriklerAsync(List<BakimPlani> planlar)
    {
        await using var ctx = await DbFactory.CreateDbContextAsync();

        var kayitlar = await ctx.BakimKontrolKayitlari
            .Include(k => k.ParcaSablonu)
            .AsNoTracking()
            .ToListAsync();

        var personeller  = await ctx.Personeller.AsNoTracking().ToListAsync();
        var atolyeler    = await ctx.BakimGruplari.AsNoTracking().ToListAsync();
        var yetkinlikler = await ctx.Yetkinlikler.AsNoTracking().ToListAsync();

        // ── Atölye doluluk (DÜZELTİLDİ: aylık kapasite, DevamEdiyor+Beklemede) ──
        _kullanimlar = atolyeler
            .Select(a =>
            {
                var isYuku = kayitlar
                    .Where(k => k.ParcaSablonu?.BakimGrubuId == a.Id
                             && (k.Durum == "DevamEdiyor" || k.Durum == "Beklemede"))
                    .Sum(k => k.ParcaSablonu?.IslemSure ?? 60);

                int aktif = personeller.Count(p =>
                    p.BakimGrubuId == a.Id && p.Durum == "Aktif" &&
                    !(p.IzinBaslangic.HasValue &&
                      DateTime.UtcNow.Date >= p.IzinBaslangic.Value.Date &&
                      (!p.IzinBitis.HasValue || DateTime.UtcNow.Date <= p.IzinBitis.Value.Date)));

                double kapasite = aktif > 0 ? aktif * 20.0 * 408 : 408 * 20.0;
                double oran = Math.Min(Math.Round(isYuku / kapasite * 100, 1), 100);
                string renk = oran >= 90 ? "#ef4444" : oran >= 70 ? "#facc15" : oran >= 40 ? "#3b82f6" : "#22c55e";
                return new AtolYeKullanimDto(a.GrupAdi, oran, renk, aktif);
            })
            .Where(x => x.ToplamPersonel > 0)
            .ToList();

        // ── Atölye bazlı olgunluk yüzdesi ────────────────────────────────────
        // Olgunluk = her personelin kendi yetkinliklerindeki maks. SV'nin atölye ortalaması / 5 × 100
        // Personel ↔ Atölye eşleşmesi: AtolyeKodu string veya BakimGrubuId FK (hangisi doluysa)
        _atolyeOlgunlukData = atolyeler
            .Select(a =>
            {
                var pIds = personeller
                    .Where(p => p.AtolyeKodu == a.AtolyeKodu
                             || p.BakimGrubuId == a.Id)
                    .Select(p => p.Id)
                    .Distinct()
                    .ToHashSet();

                double olgunluk = 0;
                if (pIds.Count > 0)
                {
                    // Her personel için kendi en yüksek SV'si (yetkinliği olmayan → 1)
                    var svOrtalama = pIds
                        .Select(pid =>
                        {
                            var maxSv = yetkinlikler
                                .Where(y => y.PersonelId == pid)
                                .Select(y => y.YetkinlikSeviyesi)
                                .DefaultIfEmpty(1)
                                .Max();
                            return (double)maxSv;
                        })
                        .Average();
                    olgunluk = Math.Round(svOrtalama / 5.0 * 100, 1);
                }

                return new ChartData { Label = a.GrupAdi, Value = (decimal)olgunluk };
            })
            .ToList();

        // ── Ort. SV ──────────────────────────────────────────────────────────
        _ortSv = await ctx.Yetkinlikler.AnyAsync()
            ? Math.Round(await ctx.Yetkinlikler.AverageAsync(y => (double)y.YetkinlikSeviyesi), 2)
            : 0;

        // ── Personel breakdown ───────────────────────────────────────────────
        _aktifPersonel  = personeller.Count(p => p.Durum == "Aktif");
        _izinliPersonel = personeller.Count(p => p.Durum == "İzinli");

        // ── SV3+ personel ─────────────────────────────────────────────────────
        _sv3PlusPersonel = await ctx.Yetkinlikler
            .Where(y => y.YetkinlikSeviyesi >= 3)
            .Select(y => y.PersonelId)
            .Distinct()
            .CountAsync();

        // ── Uçak sayısı (distinct SeriNo) ────────────────────────────────────
        _ucakSayisi = await ctx.BakimPlanlari
            .Select(b => b.SeriNo)
            .Distinct()
            .CountAsync();

        // ── Atanmamış iş emri ─────────────────────────────────────────────────
        _atanmamisIs = kayitlar.Count(k =>
            k.Durum == "Beklemede" && !k.AtananPersonelId.HasValue);

        // ── Bu hafta aktif iş ─────────────────────────────────────────────────
        var haftaBasi = DateTime.UtcNow.Date.AddDays(-(int)DateTime.UtcNow.DayOfWeek);
        var haftaSonu = haftaBasi.AddDays(7);
        _buHaftaIs = kayitlar.Count(k =>
            k.IslemTarihi >= haftaBasi && k.IslemTarihi < haftaSonu);

        // ── Ort. performans katsayısı (η = gerçek/planlanan süre) ────────────
        var tamamlananlar = kayitlar.Where(k =>
            k.Durum == "Tamamlandi" &&
            k.TamamlanmaTarihi.HasValue &&
            k.IslemTarihi > DateTime.MinValue &&
            (k.ParcaSablonu?.IslemSure ?? 0) > 0).ToList();

        if (tamamlananlar.Any())
        {
            _ortPerformans = Math.Round(tamamlananlar.Average(k =>
            {
                double gercek    = (k.TamamlanmaTarihi!.Value - k.IslemTarihi).TotalMinutes;
                double planlanan = k.ParcaSablonu!.IslemSure;
                return Math.Max(0.1, gercek / planlanan);
            }), 2);
        }

        // ── Bu ay doluluk ─────────────────────────────────────────────────────
        var buAy  = DateTime.UtcNow.Month;
        var buYil = DateTime.UtcNow.Year;
        var tahmin = await ctx.YillikIsgucuTahminleri
            .FirstOrDefaultAsync(t => t.Yil == buYil && t.Ay == buAy);

        if (tahmin != null)
        {
            _buAyDoluluk = Math.Round(tahmin.DolulukOrani, 1);
        }
        else if (_aktifPersonel > 0)
        {
            int bekleyenDk = kayitlar
                .Where(k => k.Durum == "Beklemede")
                .Sum(k => k.ParcaSablonu?.IslemSure ?? 60);
            _buAyDoluluk = Math.Round(bekleyenDk / (double)(_aktifPersonel * 20 * 408) * 100, 1);
        }

        // ── Son faaliyetler (atanan/toplam iş emri ile birlikte) ─────────────
        recentPlanlar = planlar.Take(5)
            .Select(p =>
            {
                int toplam = kayitlar.Count(k => k.BakimPlaniId == p.Id);
                int atanan = kayitlar.Count(k => k.BakimPlaniId == p.Id && k.AtananPersonelId.HasValue);
                return new BakimPlaniSatir(p, atanan, toplam);
            })
            .ToList();
    }

    private Color GetDurumColor(BakimDurumu durum) => durum switch
    {
        BakimDurumu.Beklemede   => Color.Info,
        BakimDurumu.DevamEdiyor => Color.Warning,
        BakimDurumu.Tamamlandi  => Color.Success,
        _                        => Color.Default
    };

    public class ChartData { public string Label { get; set; } = ""; public decimal? Value { get; set; } }
}
